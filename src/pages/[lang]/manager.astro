              <div class="flex items-center gap-2 text-dynamic-accent font-bold">
                <span class="w-2 h-2 bg-dynamic-accent animate-pulse"></span> Active & Optimizing
              </div>
            </div>
          </div>

          <!-- Text -->
          <div class="reveal-up order-1 lg:order-2">
            <h2 class="font-display text-3xl sm:text-5xl font-extrabold uppercase mb-6 text-dynamic-accent">
              <span set:html={lang === 'es' ? 'Autopilot<br/>Activado.' : 'Autopilot<br/>Activated.'}></span>
            </h2>
            <div class="w-16 h-1 bg-dynamic-accent mb-6"></div>
            <p class="text-lg text-[var(--tech-text-muted)] font-medium mb-8">
              {lang === 'es'
                ? 'No es solo un chatbot. Es un agente inteligente integrado directamente en el core de tu sistema de reservas.'
                : 'Not just a chatbot. It is an intelligent agent integrated directly into the core of your booking system.'}
            </p>
            <ul class="space-y-4 font-mono text-xs font-medium text-[var(--tech-text)]">
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-dynamic-accent">›</span>
                <span>{lang === 'es' ? 'Optimización de Huecos: Detecta y recomienda cierre de franjas ineficientes.' : 'Gap Optimization: Detects and recommends closing inefficient time slots.'}</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-dynamic-accent">›</span>
                <span>{lang === 'es' ? 'Modo Interrogación: "Muéstrame el revenue del fin de semana pasado frente al anterior".' : 'Interrogation Mode: "Show me last weekend\'s revenue versus the previous one".'}</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-dynamic-accent">›</span>
                <span>{lang === 'es' ? 'Análisis Predictivo: Anticipa carga de trabajo basándose en datos históricos.' : 'Predictive Analysis: Anticipates workload based on historical data.'}</span>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- WAITLIST FORM -->
    <section id="waitlist" class="py-24 sm:py-32 px-6 sm:px-8 border-b theme-border bg-dot-grid-dense flex items-center justify-center">
      <div class="max-w-2xl w-full mx-auto relative reveal-up">
        <div class="blueprint-frame p-8 sm:p-12 text-center bg-[var(--tech-bg)]">
           <div class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-[var(--tech-text-muted)] mb-4 block">
             {lang === 'es' ? 'Beta Privada' : 'Private Beta'}
           </div>
           <h2 class="font-display text-4xl sm:text-5xl font-extrabold uppercase mb-6 text-dynamic-accent">
             {lang === 'es' ? 'Sé el primero en enterarte' : 'Be the first to know'}
           </h2>
           <p class="text-[var(--tech-text-muted)] mb-10 max-w-md mx-auto">
             {lang === 'es' ? 'Apúntate a la lista de espera para recibir acceso anticipado. Cupos estrictamente limitados.' : 'Join the waitlist for early access. Spots strictly limited.'}
           </p>
           
           <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto" onsubmit="event.preventDefault(); alert('Gracias por tu interés.');">
             <input type="email" required placeholder="tu@email.com" class="flex-1 bg-transparent border theme-border font-mono text-sm px-6 py-4 focus:outline-none focus:border-dynamic-accent text-[var(--tech-text)] placeholder-[var(--tech-text-muted)] transition-colors" />
             <button type="submit" class="bg-dynamic-accent text-dynamic-bg font-mono font-bold uppercase tracking-widest text-xs px-8 py-4 hover:opacity-90 transition-opacity">
               {lang === 'es' ? 'MANTENME INFORMADO' : 'NOTIFY ME'}
             </button>
           </form>
        </div>
      </div>
    </section>

    <!-- THEME SWAPPER (FOOTER UPPER) -->
    <div class="border-b theme-border py-8 px-6 bg-dynamic-surface">
      <div class="max-w-7xl mx-auto flex flex-col items-center justify-center gap-6">
        <span class="font-mono text-[10px] uppercase font-bold tracking-widest text-[var(--tech-text-muted)]">
          {lang === 'es' ? 'Seleccionar Paleta:' : 'Select Brand Palette:'}
        </span>
        <div class="flex flex-wrap justify-center gap-4">
          <button onclick="setTheme('default')" data-theme="default" title="Marketplace Blue" class="theme-btn w-8 h-8 rounded-full border-2 border-[rgba(0,151,178,0.2)] bg-white flex items-center justify-center transition-transform scale-110 border-dynamic-accent">
             <span class="w-3 h-3 rounded-full bg-[#0097b2]"></span>
          </button>
          
          <button onclick="setTheme('mono')" data-theme="mono" title="Minimal Mono" class="theme-btn w-8 h-8 rounded-full border-2 border-transparent hover:border-dynamic-accent bg-white flex items-center justify-center transition-transform">
             <span class="w-3 h-3 rounded-full bg-[#000000]"></span>
          </button>
          
          <button onclick="setTheme('tropical')" data-theme="tropical" title="Tropical" class="theme-btn w-8 h-8 rounded-full border-2 border-transparent hover:border-dynamic-accent bg-[#0d3d34] flex items-center justify-center transition-transform">
             <span class="w-3 h-3 rounded-full bg-[#1f6357]"></span>
          </button>
          
          <button onclick="setTheme('twilight')" data-theme="twilight" title="Twilight" class="theme-btn w-8 h-8 rounded-full border-2 border-transparent hover:border-dynamic-accent bg-[#111827] flex items-center justify-center transition-transform">
             <span class="w-3 h-3 rounded-full bg-[#4338ca]"></span>
          </button>

          <button onclick="setTheme('vista')" data-theme="vista" title="Vista" class="theme-btn w-8 h-8 rounded-full border-2 border-transparent hover:border-dynamic-accent bg-[#2a0f08] flex items-center justify-center transition-transform">
             <span class="w-3 h-3 rounded-full bg-[#d56a34]"></span>
          </button>

          <button onclick="setTheme('mint')" data-theme="mint" title="Mint" class="theme-btn w-8 h-8 rounded-full border-2 border-transparent hover:border-dynamic-accent bg-[#163d39] flex items-center justify-center transition-transform">
             <span class="w-3 h-3 rounded-full bg-[#1f756e]"></span>
          </button>

          <button onclick="setTheme('sunset')" data-theme="sunset" title="Sunset" class="theme-btn w-8 h-8 rounded-full border-2 border-transparent hover:border-dynamic-accent bg-[#2a1118] flex items-center justify-center transition-transform">
             <span class="w-3 h-3 rounded-full bg-[#ff6b9d]"></span>
          </button>

          <button onclick="setTheme('ocean')" data-theme="ocean" title="Ocean" class="theme-btn w-8 h-8 rounded-full border-2 border-transparent hover:border-dynamic-accent bg-[#003d47] flex items-center justify-center transition-transform">
             <span class="w-3 h-3 rounded-full bg-[#006d77]"></span>
          </button>

          <button onclick="setTheme('nature')" data-theme="nature" title="Nature" class="theme-btn w-8 h-8 rounded-full border-2 border-transparent hover:border-dynamic-accent bg-[#112d21] flex items-center justify-center transition-transform">
             <span class="w-3 h-3 rounded-full bg-[#2d6a4f]"></span>
          </button>

          <button onclick="setTheme('lavender')" data-theme="lavender" title="Lavender" class="theme-btn w-8 h-8 rounded-full border-2 border-transparent hover:border-dynamic-accent bg-[#2b2438] flex items-center justify-center transition-transform">
             <span class="w-3 h-3 rounded-full bg-[#9d84b7]"></span>
          </button>

          <button onclick="setTheme('fire')" data-theme="fire" title="Fire" class="theme-btn w-8 h-8 rounded-full border-2 border-transparent hover:border-dynamic-accent bg-[#330000] flex items-center justify-center transition-transform">
             <span class="w-3 h-3 rounded-full bg-[#ff4500]"></span>
          </button>
        </div>
      </div>
    </div>

    <!-- FOOTER -->
    <footer class="bg-dynamic-accent text-dynamic-bg pt-20 pb-12 px-6 sm:px-8 overflow-hidden relative selection:bg-[var(--tech-bg)] selection:text-[var(--tech-accent)] transition-colors duration-400">
      <div class="max-w-7xl mx-auto relative z-10 grid grid-cols-1 md:grid-cols-4 gap-12 mb-20">
        
        <div class="md:col-span-2">
          <div class="flex items-center gap-3 mb-6 relative z-20">
            <span class="font-display text-2xl font-extrabold tracking-tight" style="color: var(--tech-bg);">EscapeMaster</span>
          </div>
          <p class="opacity-60 text-sm max-w-sm font-grotesk relative z-20">
            {lang === 'es'
              ? 'Infraestructura de software para escape rooms que buscan eficiencia y control absoluto.'
              : 'Software infrastructure for escape rooms seeking efficiency and absolute control.'}
          </p>
        </div>
        
        <div class="font-mono text-xs">
          <h4 class="opacity-40 uppercase tracking-widest mb-4">{lang === 'es' ? 'Navegación' : 'Navigation'}</h4>
          <ul class="space-y-3">
            <li><a href="#features" class="hover:opacity-60 transition-opacity">{lang === 'es' ? 'Características' : 'Features'}</a></li>
            <li><a href="#compare" class="hover:opacity-60 transition-opacity">{lang === 'es' ? 'Comparativa' : 'Compare'}</a></li>
            <li><a href="#pricing" class="hover:opacity-60 transition-opacity">{lang === 'es' ? 'Precios' : 'Pricing'}</a></li>
            <li><a href="#faq" class="hover:opacity-60 transition-opacity">FAQ</a></li>
            <li><a href="https://manager.escapemaster.es" class="hover:opacity-60 transition-opacity">{lang === 'es' ? 'Iniciar Sesión' : 'Login'}</a></li>
          </ul>
        </div>
        
        <div class="font-mono text-xs">
          <h4 class="opacity-40 uppercase tracking-widest mb-4">Legal</h4>
          <ul class="space-y-3">
            <li><a href={`/${lang}/privacidad`} class="hover:opacity-60 transition-opacity">{lang === 'es' ? 'Privacidad' : 'Privacy Policy'}</a></li>
            <li><a href={`/${lang}/terminos`} class="hover:opacity-60 transition-opacity">{lang === 'es' ? 'Términos' : 'Terms of Service'}</a></li>
            <li><a href="mailto:hello@escapemaster.es" class="hover:opacity-60 transition-opacity">{lang === 'es' ? 'Contacto' : 'Contact'}</a></li>
          </ul>
        </div>

      </div>

      <!-- Giant Pixel/Dot Brand Name -->
      <div class="max-w-7xl mx-auto border-t border-[var(--tech-bg)]/20 pt-12 text-center select-none opacity-40 relative">
         <h1 class="font-display uppercase font-black text-[12vw] leading-none tracking-tighter text-transparent" style="-webkit-text-stroke: 1px var(--tech-bg);">
           MANAGER.
         </h1>
      </div>
    </footer>
  </div>
  
  <style>
    /* CSS specific keyframes for marquee */
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-\[marquee_20s_linear_infinite\] {
      animation: marquee 20s linear infinite;
    }
  </style>
</BareLayout>
