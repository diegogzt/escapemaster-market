---
import Layout from '../../layouts/Layout.astro';
import { Eye, EyeOff } from 'lucide-react';

const { lang } = Astro.params;

const t = lang === 'en' ? {
  title: 'Sign In',
  email: 'Email',
  password: 'Password',
  button: 'Sign in',
  loading: 'Signing in...',
  remember: 'Remember me',
  noAccount: "Don't have an account?",
  register: 'Register here',
  error: 'Invalid credentials',
  forgot: 'Forgot your password?',
  subtitle: 'Welcome back to EscapeMaster',
  orContinueWith: 'OR CONTINUE WITH',
} : {
  title: 'Iniciar Sesión',
  email: 'Correo electrónico',
  password: 'Contraseña',
  button: 'Entrar',
  loading: 'Entrando...',
  remember: 'Recordarme',
  noAccount: '¿No tienes cuenta?',
  register: 'Regístrate aquí',
  error: 'Credenciales inválidas',
  forgot: '¿Olvidaste tu contraseña?',
  subtitle: 'Bienvenido de nuevo a EscapeMaster',
  orContinueWith: 'O CONTINÚA CON',
};
---

<Layout title={`${t.title} | EscapeMaster`} hideFooter>
  <main class="min-h-[calc(100vh-5rem)] flex items-center justify-center px-4 py-10
    bg-tropical-bg
    bg-[radial-gradient(var(--color-tropical-secondary)_1px,transparent_1px)]
    [background-size:22px_22px]">

    <div class="w-full max-w-md">

      <!-- Logo + Brand -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-tropical-primary rounded-2xl shadow-xl shadow-tropical-primary/30 mb-4">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" class="text-white">
            <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="currentColor"/>
            <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h1 class="text-2xl font-black tracking-tight text-tropical-text">{t.title}</h1>
        <p class="text-sm text-tropical-text/50 mt-1">{t.subtitle}</p>
      </div>

      <!-- Card -->
      <div class="bg-white/90 backdrop-blur-xl rounded-2xl shadow-2xl shadow-tropical-primary/10 border border-tropical-secondary/10 p-8">

        <form id="loginForm" class="space-y-5">
          <!-- Email -->
          <div class="space-y-1.5">
            <label for="email" class="text-xs font-bold uppercase tracking-wider text-tropical-text/50">{t.email}</label>
            <input
              type="email"
              id="email"
              required
              inputmode="email"
              autocapitalize="none"
              autocomplete="email"
              spellcheck="false"
              placeholder="tu@email.com"
              class="w-full h-12 px-4 rounded-xl bg-tropical-bg/60 border-0 ring-1 ring-inset ring-tropical-secondary/20 focus:ring-2 focus:ring-inset focus:ring-tropical-primary outline-none transition-all text-sm font-medium text-tropical-text placeholder:text-tropical-text/30"
            />
          </div>

          <!-- Password -->
          <div class="space-y-1.5">
            <label for="password" class="text-xs font-bold uppercase tracking-wider text-tropical-text/50">{t.password}</label>
            <div class="relative">
              <input
                type="password"
                id="password"
                required
                placeholder="••••••••"
                class="w-full h-12 px-4 pr-12 rounded-xl bg-tropical-bg/60 border-0 ring-1 ring-inset ring-tropical-secondary/20 focus:ring-2 focus:ring-inset focus:ring-tropical-primary outline-none transition-all text-sm font-medium text-tropical-text placeholder:text-tropical-text/30"
              />
              <button
                type="button"
                id="togglePassword"
                class="absolute inset-y-0 right-0 px-3 text-tropical-text/40 hover:text-tropical-primary transition-colors"
                aria-label="Mostrar u ocultar contraseña"
              >
                <Eye size={18} id="eyeOpen" />
                <EyeOff size={18} id="eyeClosed" className="hidden" />
              </button>
            </div>
          </div>

          <!-- Remember + Forgot -->
          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 text-sm text-tropical-text/60 cursor-pointer select-none">
              <input id="rememberMe" type="checkbox" class="w-4 h-4 rounded border-tropical-secondary/30 text-tropical-primary focus:ring-tropical-primary" />
              <span>{t.remember}</span>
            </label>
            <a href={`/${lang}/forgot-password`} class="text-xs font-semibold text-tropical-primary hover:underline">
              {t.forgot}
            </a>
          </div>

          <!-- Error -->
          <div id="errorMsg" class="hidden text-sm font-medium text-red-600 bg-red-50 p-3 rounded-xl border border-red-100 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
            <span id="errorText">{t.error}</span>
          </div>

          <!-- Submit -->
          <button
            id="submitBtn"
            type="submit"
            class="w-full h-12 bg-tropical-primary hover:bg-tropical-secondary text-white font-bold uppercase tracking-wider text-sm rounded-xl transition-all hover:scale-[0.98] active:scale-95 shadow-lg shadow-tropical-primary/20"
          >
            <span id="submitText">{t.button}</span>
          </button>
        </form>

        <!-- Divider -->
        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center">
            <span class="w-full border-t border-tropical-secondary/15"></span>
          </div>
          <div class="relative flex justify-center">
            <span class="px-4 bg-white text-[10px] font-bold tracking-widest uppercase text-tropical-text/40">{t.orContinueWith}</span>
          </div>
        </div>

        <!-- Google -->
        <button
          id="googleLoginBtn"
          type="button"
          class="w-full flex items-center justify-center gap-3 h-12 bg-white border border-tropical-secondary/15 rounded-xl hover:bg-tropical-bg hover:border-tropical-primary/30 transition-all shadow-sm active:scale-[0.98] font-semibold text-sm text-tropical-text/70"
        >
          <svg viewBox="0 0 24 24" width="18" height="18">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Google
        </button>

        <!-- Register link -->
        <p class="mt-6 text-center text-sm text-tropical-text/50">
          {t.noAccount}
          <a href={`/${lang}/register`} class="font-bold text-tropical-primary hover:underline ml-1">{t.register}</a>
        </p>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { auth } from '../../lib/auth';
  import { requestGoogleCredential } from '../../lib/google-auth';

  const form = document.getElementById('loginForm') as HTMLFormElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;
  const errorText = document.getElementById('errorText') as HTMLElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const togglePassword = document.getElementById('togglePassword') as HTMLButtonElement;
  const eyeOpen = document.getElementById('eyeOpen') as HTMLElement;
  const eyeClosed = document.getElementById('eyeClosed') as HTMLElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const submitText = document.getElementById('submitText') as HTMLElement;
  const googleBtn = document.getElementById('googleLoginBtn') as HTMLButtonElement;
  const googleLoginEnabled = Boolean(import.meta.env.PUBLIC_GOOGLE_CLIENT_ID?.trim());

  const originalText = submitText?.textContent || 'Entrar';
  const currentLang = window.location.pathname.split('/')[1] || 'es';
  const loadingText = currentLang === 'en' ? 'Signing in...' : 'Entrando...';

  if (!googleLoginEnabled && googleBtn) {
    googleBtn.disabled = true;
    googleBtn.classList.add('opacity-40', 'cursor-not-allowed');
  }

  togglePassword?.addEventListener('click', () => {
    const isPassword = passwordInput.type === 'password';
    passwordInput.type = isPassword ? 'text' : 'password';
    eyeOpen.classList.toggle('hidden', isPassword);
    eyeClosed.classList.toggle('hidden', !isPassword);
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    submitBtn.disabled = true;
    submitText.textContent = loadingText;

    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const rememberMe = (document.getElementById('rememberMe') as HTMLInputElement)?.checked;

    try {
      const result = await auth.login(email, password);
      if (rememberMe) localStorage.setItem('em_remember_email', email);
      else localStorage.removeItem('em_remember_email');
      const lang = window.location.pathname.split('/')[1] || 'es';
      const user = result?.user;
      if (user && user.onboarding_completed === false) {
        window.location.href = `/${lang}/onboarding`;
      } else {
        window.location.href = `/${lang}/profile`;
      }
    } catch (err: any) {
      if (err.requiresVerification) {
        const lang = window.location.pathname.split('/')[1] || 'es';
        window.location.href = `/${lang}/register?verify=${encodeURIComponent(err.email)}`;
        return;
      }
      if (errorText) errorText.textContent = err.message;
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = originalText;
    }
  });

  googleBtn?.addEventListener('click', async () => {
    errorMsg.classList.add('hidden');
    submitBtn.disabled = true;
    googleBtn.disabled = true;
    submitText.textContent = loadingText;

    try {
      const credential = await requestGoogleCredential();
      await auth.loginWithGoogle(credential);
      const lang = window.location.pathname.split('/')[1] || 'es';
      const session = await auth.getSession();
      if (session.user && !session.user.onboarding_completed) {
        window.location.href = `/${lang}/onboarding`;
      } else {
        window.location.href = `/${lang}/profile`;
      }
    } catch (err: any) {
      if (errorText) errorText.textContent = err.message;
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      googleBtn.disabled = false;
      submitText.textContent = originalText;
    }
  });

  const rememberedEmail = localStorage.getItem('em_remember_email');
  if (rememberedEmail) {
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const rememberCheckbox = document.getElementById('rememberMe') as HTMLInputElement;
    emailInput.value = rememberedEmail;
    rememberCheckbox.checked = true;
  }
</script>
