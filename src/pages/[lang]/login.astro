---
import Layout from '../../layouts/Layout.astro';
import { Button } from '../../components/ui/Button';
import { Lock, Eye, EyeOff } from 'lucide-react';

const { lang } = Astro.params;

const t = lang === 'en' ? {
  title: 'Sign In',
  email: 'Email',
  password: 'Password',
  button: 'Sign in',
  loading: 'Signing in...',
  remember: 'Remember me',
  noAccount: 'Don\'t have an account?',
  register: 'Register here',
  error: 'Invalid credentials',
  forgot: 'Forgot your password?',
  subtitle: 'Access your EscapeMaster account',
  accountTypeTitle: 'How do you want to sign in?',
  accountTypePlayer: 'Player',
  accountTypeEnterprise: 'Business',
  orgName: 'Business name',
  orgNamePh: 'My Escape Room Inc.',
  orgRequired: 'Business name is required',
  orContinueWith: 'OR CONTINUE WITH',
} : {
  title: 'Iniciar Sesión',
  email: 'Correo electrónico',
  password: 'Contraseña',
  button: 'Iniciar sesión',
  loading: 'Entrando...',
  remember: 'Recordarme',
  noAccount: '¿No tienes cuenta?',
  register: 'Regístrate aquí',
  error: 'Credenciales inválidas',
  forgot: '¿Olvidaste tu contraseña?',
  subtitle: 'Accede a tu cuenta de EscapeMaster',
  accountTypeTitle: '¿Cómo quieres acceder?',
  accountTypePlayer: 'Jugador',
  accountTypeEnterprise: 'Empresa',
  orgName: 'Nombre de la empresa',
  orgNamePh: 'Mi Escape Room S.L.',
  orgRequired: 'El nombre de la empresa es obligatorio',
  orContinueWith: 'O CONTINUA CON',
};
---

<Layout title={`${t.title} | EscapeMaster`} hideFooter>
  <main class="min-h-[calc(100vh-6rem)] py-8 sm:py-12 bg-tropical-bg flex items-center justify-center">
    <div class="w-full max-w-md mx-auto px-4 sm:px-0">
      <div class="bg-white rounded-xl sm:rounded-2xl shadow-2xl overflow-hidden border border-tropical-secondary/10">
        <div class="p-6 sm:p-8">
          <div class="text-center mb-8 sm:mb-10">
            <div class="w-16 h-16 bg-tropical-primary rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
              <Lock size={28} className="text-white" />
            </div>
            <h1 class="text-2xl sm:text-3xl font-bold text-tropical-text mb-2">{t.title}</h1>
            <p class="text-sm sm:text-base text-tropical-text/70">{t.subtitle}</p>
          </div>

          <form id="loginForm" class="space-y-4 sm:space-y-6">
            <div>
              <label for="email" class="block text-sm font-medium text-tropical-text mb-1">{t.email}</label>
              <input
                type="email"
                id="email"
                required
                inputmode="email"
                autocapitalize="none"
                autocomplete="email"
                spellcheck="false"
                class="w-full px-4 py-3 rounded-xl border border-tropical-secondary/30 focus:ring-2 focus:ring-tropical-secondary focus:border-transparent transition-all outline-none text-base input-mobile"
                placeholder="tu@email.com"
              />
            </div>

            <div>
              <label for="password" class="block text-sm font-medium text-tropical-text mb-1">{t.password}</label>
              <div class="relative">
                <input
                  type="password"
                  id="password"
                  required
                  class="w-full px-4 py-3 pr-12 rounded-xl border border-tropical-secondary/30 focus:ring-2 focus:ring-tropical-secondary focus:border-transparent transition-all outline-none text-base input-mobile"
                  placeholder="********"
                />
                <button
                  type="button"
                  id="togglePassword"
                  class="absolute inset-y-0 right-0 px-3 text-tropical-text/60 hover:text-tropical-primary touch-manipulation"
                  aria-label="Mostrar u ocultar contraseña"
                >
                  <Eye size={20} id="eyeOpen" />
                  <EyeOff size={20} id="eyeClosed" className="hidden" />
                </button>
              </div>
            </div>

            <label class="flex items-center gap-2 text-sm text-tropical-text/80 cursor-pointer select-none">
              <input id="rememberMe" type="checkbox" class="w-4 h-4 rounded border-tropical-secondary/40 text-tropical-primary focus:ring-tropical-secondary" />
              <span>{t.remember}</span>
            </label>

            <div id="errorMsg" class="hidden text-tropical-accent text-sm bg-tropical-accent/10 p-3 rounded-lg border border-tropical-accent/20">
              {t.error}
            </div>

            <Button id="submitBtn" type="submit" className="w-full py-3.5 sm:py-4 text-base sm:text-lg active:scale-[0.98] transition-transform touch-manipulation min-h-11">
              <span id="submitText">{t.button}</span>
            </Button>
          </form>

          <div class="relative my-5">
            <div class="absolute inset-0 flex items-center">
              <span class="w-full border-t border-tropical-secondary/20"></span>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-4 bg-white text-tropical-text/50 uppercase tracking-widest font-bold text-[10px]">{t.orContinueWith}</span>
            </div>
          </div>

          <div class="flex flex-col gap-3">
             <button
              id="googleLoginBtn"
              type="button"
              class="w-full flex items-center justify-center gap-3 py-3.5 px-4 bg-white border-2 border-tropical-secondary/15 rounded-xl hover:bg-tropical-secondary/5 hover:border-tropical-primary/30 transition-all shadow-sm active:scale-[0.98] group"
             >
                <svg viewBox="0 0 24 24" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <span class="text-tropical-text/70 font-bold">Google</span>
             </button>
          </div>

          <div class="mt-3 text-center">
            <a href={`/${lang}/forgot-password`} class="text-sm text-tropical-text/60 hover:text-tropical-primary transition-colors">
              {t.forgot}
            </a>
          </div>

          <div class="mt-6 sm:mt-8 text-center text-sm text-tropical-text/80">
            {t.noAccount} 
            <a href={`/${lang}/register`} class="text-tropical-primary font-bold hover:underline ml-1">
              {t.register}
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { auth } from '../../lib/auth';
  import { requestGoogleCredential } from '../../lib/google-auth';

  const form = document.getElementById('loginForm') as HTMLFormElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const togglePassword = document.getElementById('togglePassword') as HTMLButtonElement;
  const eyeOpen = document.getElementById('eyeOpen') as HTMLElement;
  const eyeClosed = document.getElementById('eyeClosed') as HTMLElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const submitText = document.getElementById('submitText') as HTMLElement;
  const googleBtn = document.getElementById('googleLoginBtn') as HTMLButtonElement;
  const googleLoginEnabled = Boolean(import.meta.env.PUBLIC_GOOGLE_CLIENT_ID?.trim());

  const originalText = submitText?.textContent || 'Entrar';
  const currentLang = window.location.pathname.split('/')[1] || 'es';
  const loadingText = currentLang === 'en' ? 'Signing in...' : 'Entrando...';

  if (!googleLoginEnabled && googleBtn) {
    googleBtn.disabled = true;
    googleBtn.title = currentLang === 'en'
      ? 'Google login is not configured in this environment'
      : 'El login con Google no esta configurado en este entorno';
    googleBtn.classList.add('opacity-60', 'cursor-not-allowed');
  }

  togglePassword?.addEventListener('click', () => {
    const isPassword = passwordInput.type === 'password';
    passwordInput.type = isPassword ? 'text' : 'password';
    eyeOpen.classList.toggle('hidden', isPassword);
    eyeClosed.classList.toggle('hidden', !isPassword);
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    submitBtn.disabled = true;
    submitText.textContent = loadingText;

    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const rememberMe = (document.getElementById('rememberMe') as HTMLInputElement)?.checked;

    try {
      const result = await auth.login(email, password);
      if (rememberMe) localStorage.setItem('em_remember_email', email);
      else localStorage.removeItem('em_remember_email');
      const lang = window.location.pathname.split('/')[1] || 'es';
      const user = result?.user;
      if (user && user.onboarding_completed === false) {
        window.location.href = `/${lang}/onboarding`;
      } else {
        window.location.href = `/${lang}/profile`;
      }
    } catch (err: any) {
      // If account requires verification, redirect to register page step 2
      if (err.requiresVerification) {
        const lang = window.location.pathname.split('/')[1] || 'es';
        window.location.href = `/${lang}/register?verify=${encodeURIComponent(err.email)}`;
        return;
      }
      errorMsg.textContent = err.message;
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = originalText;
    }
  });

  // Google Login Logic — auto-detect account type based on organization
  googleBtn?.addEventListener('click', async () => {
    errorMsg.classList.add('hidden');
    submitBtn.disabled = true;
    googleBtn.disabled = true;
    if (submitText) submitText.textContent = loadingText;

    try {
      const credential = await requestGoogleCredential();
      // Pass no accountType - let backend detect or default to customer
      await auth.loginWithGoogle(credential);

      const lang = window.location.pathname.split('/')[1] || 'es';
      const session = await auth.getSession();
      if (session.user && !session.user.onboarding_completed) {
        window.location.href = `/${lang}/onboarding`;
      } else {
        window.location.href = `/${lang}/profile`;
      }
    } catch (err: any) {
      if (errorMsg) {
        errorMsg.textContent = err.message;
        errorMsg.classList.remove('hidden');
      }
    } finally {
      submitBtn.disabled = false;
      googleBtn.disabled = false;
      if (submitText) submitText.textContent = originalText;
    }
  });

  const rememberedEmail = localStorage.getItem('em_remember_email');
  if (rememberedEmail) {
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const rememberCheckbox = document.getElementById('rememberMe') as HTMLInputElement;
    emailInput.value = rememberedEmail;
    rememberCheckbox.checked = true;
  }
</script>
