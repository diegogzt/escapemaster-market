---
import Layout from '../../../layouts/Layout.astro';
import { pool } from '../../../lib/db';
import { ui } from '../../../i18n/ui';

const { lang = 'es' } = Astro.params;
const t = ui[lang as keyof typeof ui] || ui.es;

let offers: any[] = [];

try {
  const result = await pool.query(`
    SELECT of.*, r.name as room_name, r.image_url as room_image, r.city as room_city,
           r.duration_minutes, r.capacity_min, r.capacity, r.difficulty_level,
           r.average_rating, r.total_reviews, r.price_per_person,
           o.name as org_name
    FROM offers of
    JOIN rooms r ON r.id = of.room_id
    LEFT JOIN organizations o ON o.id = r.organization_id
    WHERE of.is_active = true
      AND r.is_active = true
      AND (of.valid_until IS NULL OR of.valid_until >= NOW())
      AND (of.max_uses IS NULL OR of.current_uses < of.max_uses)
    ORDER BY of.offer_type, of.discount_percentage DESC NULLS LAST
  `);
  offers = result.rows;
} catch (e) {
  console.error('Error loading offers:', e);
}

function getOfferBadge(type: string) {
  switch(type) {
    case 'discount': return { text: lang === 'es' ? 'Descuento' : 'Discount', color: 'bg-rose-600', icon: '🏷️' };
    case '2x1': return { text: '2x1', color: 'bg-violet-600', icon: '🎉' };
    case 'happy_hour': return { text: 'Happy Hour', color: 'bg-amber-500', icon: '⏰' };
    case 'last_minute': return { text: lang === 'es' ? 'Última Hora' : 'Last Minute', color: 'bg-orange-500', icon: '⚡' };
    default: return { text: 'Oferta', color: 'bg-tropical-primary', icon: '🎁' };
  }
}

function getOfferGradient(type: string) {
  switch(type) {
    case 'discount': return 'from-rose-500/10 to-rose-600/5';
    case '2x1': return 'from-violet-500/10 to-violet-600/5';
    case 'happy_hour': return 'from-amber-500/10 to-amber-600/5';
    case 'last_minute': return 'from-orange-500/10 to-orange-600/5';
    default: return 'from-tropical-primary/10 to-tropical-secondary/5';
  }
}

function formatDate(date: string) {
  return new Date(date).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Layout title={`${t['offers.title']} | EscapeMaster`}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    .font-display { font-family: 'Manrope', system-ui, sans-serif; }
    .font-body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      33% { transform: translateY(-12px) rotate(3deg); }
      66% { transform: translateY(-6px) rotate(-2deg); }
    }
    @keyframes float-reverse {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      33% { transform: translateY(10px) rotate(-3deg); }
      66% { transform: translateY(5px) rotate(2deg); }
    }
    @keyframes pulse-glow {
      0%, 100% { opacity: 0.6; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.05); }
    }
    @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    @keyframes slide-up-delay {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes badge-pop {
      0% { transform: scale(0.8) rotate(-5deg); opacity: 0; }
      70% { transform: scale(1.1) rotate(2deg); }
      100% { transform: scale(1) rotate(0deg); opacity: 1; }
    }

    .animate-float { animation: float 7s ease-in-out infinite; }
    .animate-float-reverse { animation: float-reverse 8s ease-in-out infinite; }
    .animate-pulse-glow { animation: pulse-glow 3s ease-in-out infinite; }
    .animate-shimmer {
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
      background-size: 200% 100%;
      animation: shimmer 2s infinite;
    }
    .animate-slide-up { animation: slide-up-delay 0.6s ease-out forwards; opacity: 0; }
    .animate-badge-pop { animation: badge-pop 0.4s ease-out forwards; }

    .offer-card { animation: slide-up-delay 0.5s ease-out forwards; opacity: 0; }
    .offer-card:nth-child(1) { animation-delay: 0.05s; }
    .offer-card:nth-child(2) { animation-delay: 0.1s; }
    .offer-card:nth-child(3) { animation-delay: 0.15s; }
    .offer-card:nth-child(4) { animation-delay: 0.2s; }
    .offer-card:nth-child(5) { animation-delay: 0.25s; }
    .offer-card:nth-child(6) { animation-delay: 0.3s; }
    .offer-card:nth-child(7) { animation-delay: 0.35s; }
    .offer-card:nth-child(8) { animation-delay: 0.4s; }
    .offer-card:nth-child(9) { animation-delay: 0.45s; }

    .filter-btn { transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .filter-btn:hover { transform: translateY(-2px); }
    .filter-btn.active { transform: none; box-shadow: 0 4px 14px rgba(0,151,178,0.35); }

    .discount-badge {
      animation: badge-pop 0.35s ease-out 0.2s both;
      transform-origin: center;
    }

    .hero-tag { animation: float 6s ease-in-out infinite; }
    .hero-tag-2 { animation: float-reverse 7s ease-in-out infinite 1s; }
    .hero-tag-3 { animation: float 9s ease-in-out infinite 2s; }

    .card-inner {
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .offer-card:hover .card-inner {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px -12px rgba(0,0,0,0.15);
    }
    .offer-card:hover .card-image {
      transform: scale(1.06);
    }
    .card-image {
      transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .cta-btn {
      position: relative;
      overflow: hidden;
    }
    .cta-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .cta-btn:hover::before { opacity: 1; }
    .cta-btn:hover { transform: translateY(-2px) scale(1.02); }
    .cta-btn:active { transform: translateY(0) scale(0.98); }

    .coupon-tag {
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
      position: relative;
    }
    .coupon-tag::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
      background-size: 200% 100%;
      animation: shimmer 2.5s infinite;
    }
  </style>

  <main class="pb-32 sm:pb-20 font-body">
    <!-- ─── Hero Section ─── -->
    <div class="relative overflow-hidden bg-gradient-to-br from-tropical-primary via-tropical-secondary to-tropical-primary min-[480px]:min-h-[320px] sm:min-h-[380px] flex items-center">
      <!-- Decorative shapes -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="hero-tag absolute top-8 right-[8%] sm:right-[15%] w-16 h-16 sm:w-24 sm:h-24 rounded-2xl bg-white/10 rotate-12 border-2 border-white/20"></div>
        <div class="hero-tag-2 absolute bottom-12 right-[25%] sm:right-[30%] w-10 h-10 sm:w-16 sm:h-16 rounded-full bg-tropical-accent/30 border border-tropical-accent/40"></div>
        <div class="hero-tag-3 absolute top-[20%] left-[5%] w-8 h-8 sm:w-14 sm:h-14 rounded-xl bg-white/10 -rotate-12 border border-white/15"></div>
        <div class="absolute bottom-[-40px] left-[50%] -translate-x-1/2 w-[600px] h-[200px] bg-white/5 rounded-[50%] blur-3xl"></div>
        <!-- Grid pattern overlay -->
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
      </div>

      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16 w-full">
        <div class="max-w-2xl">
          <!-- Eyebrow -->
          <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm text-white/90 text-xs sm:text-sm font-bold uppercase tracking-[0.2em] px-4 py-2 rounded-full mb-6 border border-white/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
            <span>{lang === 'es' ? 'Ofertas Exclusivas' : 'Exclusive Offers'}</span>
          </div>

          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[0.95] tracking-tight mb-4">
            {t['offers.title']}
          </h1>
          <p class="text-white/75 text-base sm:text-lg leading-relaxed max-w-lg">
            {t['offers.subtitle']}
          </p>

          <!-- Stats row -->
          <div class="flex gap-6 mt-8">
            <div class="text-center">
              <div class="text-2xl sm:text-3xl font-black text-white">{offers.length}</div>
              <div class="text-[10px] sm:text-xs font-bold text-white/50 uppercase tracking-wider">{lang === 'es' ? 'Ofertas activas' : 'Active offers'}</div>
            </div>
            <div class="w-px bg-white/20"></div>
            <div class="text-center">
              <div class="text-2xl sm:text-3xl font-black text-tropical-accent">{offers.filter(o => o.discount_percentage >= 20).length}</div>
              <div class="text-[10px] sm:text-xs font-bold text-white/50 uppercase tracking-wider">{lang === 'es' ? '+20% descuento' : '+20% off'}</div>
            </div>
            <div class="w-px bg-white/20"></div>
            <div class="text-center">
              <div class="text-2xl sm:text-3xl font-black text-white">{new Set(offers.map(o => o.org_name)).size}</div>
              <div class="text-[10px] sm:text-xs font-bold text-white/50 uppercase tracking-wider">{lang === 'es' ? 'Organizaciones' : 'Businesses'}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── Filter Bar ─── -->
    <div class="sticky top-16 sm:top-20 z-30 bg-white/90 backdrop-blur-xl border-b border-gray-100 shadow-sm">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4">
        <div class="flex items-center gap-3 overflow-x-auto scroll-x-smooth no-scrollbar pb-1">
          <button data-filter="all" class="filter-btn active shrink-0 bg-tropical-primary text-white px-5 py-2.5 rounded-full text-sm font-extrabold tracking-wide shadow-md">
            {lang === 'es' ? 'Todas' : 'All'}
          </button>
          <button data-filter="discount" class="filter-btn shrink-0 bg-gray-50 text-tropical-text/60 px-5 py-2.5 rounded-full text-sm font-bold hover:bg-rose-50 hover:text-rose-600 border border-gray-100">
            🏷️ {lang === 'es' ? 'Descuentos' : 'Discounts'}
          </button>
          <button data-filter="2x1" class="filter-btn shrink-0 bg-gray-50 text-tropical-text/60 px-5 py-2.5 rounded-full text-sm font-bold hover:bg-violet-50 hover:text-violet-600 border border-gray-100">
            🎉 2x1
          </button>
          <button data-filter="happy_hour" class="filter-btn shrink-0 bg-gray-50 text-tropical-text/60 px-5 py-2.5 rounded-full text-sm font-bold hover:bg-amber-50 hover:text-amber-600 border border-gray-100">
            ⏰ Happy Hour
          </button>
          <button data-filter="last_minute" class="filter-btn shrink-0 bg-gray-50 text-tropical-text/60 px-5 py-2.5 rounded-full text-sm font-bold hover:bg-orange-50 hover:text-orange-600 border border-gray-100">
            ⚡ {lang === 'es' ? 'Última Hora' : 'Last Minute'}
          </button>
        </div>
      </div>
    </div>

    <!-- ─── Offers Grid ─── -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 mt-8 sm:mt-10">
      {offers.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6" id="offers-grid">
          {offers.map((offer: any, i: number) => {
            const badge = getOfferBadge(offer.offer_type);
            const gradient = getOfferGradient(offer.offer_type);
            return (
              <div class="offer-card group relative bg-white rounded-3xl border border-gray-100 overflow-visible hover:border-transparent transition-all duration-300" data-type={offer.offer_type} style={`animation-delay: ${i * 0.06}s`}>
                <div class="absolute -inset-px rounded-3xl bg-gradient-to-br from-tropical-primary/20 to-tropical-secondary/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10"></div>

                <div class="card-inner relative rounded-3xl bg-white border border-gray-100 overflow-hidden">
                  <!-- Image -->
                  <div class="relative aspect-[16/10] overflow-hidden bg-gray-50">
                    <img
                      src={offer.room_image || 'https://images.unsplash.com/photo-1518709766631-a6a7f45921c3?w=400'}
                      alt={offer.room_name}
                      class="card-image w-full h-full object-cover"
                      loading="lazy"
                    />
                    <!-- Gradient overlay on image -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                    <!-- Top badges row -->
                    <div class="absolute top-3 left-3 flex gap-2">
                      <span class={`${badge.color} text-white text-[11px] font-extrabold px-3 py-1.5 rounded-full shadow-lg flex items-center gap-1 animate-badge-pop`}>
                        <span>{badge.icon}</span>
                        <span>{badge.text}</span>
                      </span>
                    </div>

                    <!-- Discount percentage -->
                    {offer.discount_percentage && (
                      <div class="discount-badge absolute top-3 right-3 bg-gradient-to-br from-rose-600 to-rose-700 text-white text-base font-black px-3.5 py-1.5 rounded-2xl shadow-xl rotate-2 flex items-center gap-0.5">
                        <span>-{offer.discount_percentage}%</span>
                      </div>
                    )}

                    <!-- Room city tag -->
                    <div class="absolute bottom-3 left-3">
                      <span class="bg-black/50 backdrop-blur-sm text-white/90 text-[10px] font-bold px-2.5 py-1 rounded-lg flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        {offer.room_city}
                      </span>
                    </div>
                  </div>

                  <!-- Content -->
                  <div class="p-5">
                    <h3 class="font-display font-black text-lg text-tropical-text leading-tight mb-1 group-hover:text-tropical-primary transition-colors">{offer.title}</h3>
                    {offer.description && (
                      <p class="text-tropical-text/45 text-sm leading-relaxed line-clamp-2">{offer.description}</p>
                    )}

                    <!-- Room link card -->
                    <a href={`/${lang}/game/${offer.room_id}`} class="group/card mt-3 block p-3.5 rounded-2xl bg-gradient-to-r from-tropical-card to-white border border-gray-100 hover:from-tropical-primary/5 hover:to-tropical-secondary/5 hover:border-tropical-primary/20 transition-all duration-200">
                      <p class="text-[10px] font-extrabold text-tropical-primary uppercase tracking-widest mb-0.5">{offer.org_name}</p>
                      <p class="font-bold text-sm text-tropical-text group-hover/card:text-tropical-primary transition-colors">{offer.room_name}</p>
                      <div class="flex items-center gap-2 text-[11px] text-tropical-text/40 mt-1.5">
                        <span class="flex items-center gap-1">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                          {offer.duration_minutes} min
                        </span>
                        {offer.capacity_min && offer.capacity && (
                          <>
                            <span>·</span>
                            <span class="flex items-center gap-1">
                              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                              {offer.capacity_min}-{offer.capacity}
                            </span>
                          </>
                        )}
                        {offer.average_rating && (
                          <>
                            <span>·</span>
                            <span class="flex items-center gap-0.5 text-amber-500 font-bold">
                              ★ {Number(offer.average_rating).toFixed(1)}
                            </span>
                          </>
                        )}
                      </div>
                    </a>

                    <!-- Pricing + CTA -->
                    <div class="flex items-end justify-between mt-4 gap-3">
                      <div class="flex flex-col">
                        {offer.original_price && (
                          <span class="text-xs text-tropical-text/30 line-through font-medium">{offer.original_price}€</span>
                        )}
                        {offer.offer_price ? (
                          <span class="text-2xl font-black text-tropical-primary leading-none">{offer.offer_price}€</span>
                        ) : offer.discount_percentage ? (
                          <span class="text-2xl font-black text-rose-600 leading-none">-{offer.discount_percentage}%</span>
                        ) : null}
                        <span class="text-[10px] text-tropical-text/40 font-medium mt-0.5">{lang === 'es' ? 'por persona' : 'per person'}</span>
                      </div>
                      <a href={`/${lang}/game/${offer.room_id}`} class="cta-btn shrink-0 bg-tropical-primary text-white text-sm font-extrabold px-5 py-2.5 rounded-2xl shadow-lg shadow-tropical-primary/25 transition-all">
                        {t['offers.book_now']} →
                      </a>
                    </div>

                    <!-- Footer info -->
                    <div class="flex items-center justify-between mt-4 pt-3.5 border-t border-gray-50 gap-2">
                      <div class="flex items-center gap-2 flex-wrap">
                        {offer.valid_until && (
                          <span class="text-[10px] text-tropical-text/40 font-medium flex items-center gap-1">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            {formatDate(offer.valid_until)}
                          </span>
                        )}
                        {offer.coupon_code && (
                          <span class="coupon-tag text-[10px] text-white font-extrabold px-2 py-0.5 rounded-lg font-mono shadow-sm">
                            {offer.coupon_code}
                          </span>
                        )}
                      </div>
                      {offer.conditions && (
                        <button class="text-[10px] font-bold text-tropical-primary hover:text-tropical-secondary transition-colors underline underline-offset-2 hover:no-underline" data-conditions={offer.conditions}>
                          {t['offers.conditions']}
                        </button>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <!-- Empty state -->
        <div class="text-center py-24">
          <div class="relative inline-block mb-6">
            <div class="w-24 h-24 rounded-3xl bg-tropical-card flex items-center justify-center mx-auto shadow-lg">
              <span class="text-5xl">🎁</span>
            </div>
            <div class="absolute -top-2 -right-2 w-8 h-8 rounded-full bg-tropical-accent/20 border-2 border-white shadow"></div>
            <div class="absolute -bottom-1 -left-3 w-6 h-6 rounded-full bg-tropical-primary/20 animate-pulse-glow"></div>
          </div>
          <h3 class="font-display text-2xl font-black text-tropical-text mb-2">{lang === 'es' ? 'Sin ofertas disponibles' : 'No offers available'}</h3>
          <p class="text-tropical-text/50 mb-6 max-w-sm mx-auto">{lang === 'es' ? 'Pero hay muchas salas esperándote. ¡Echa un vistazo!' : 'But many rooms are waiting for you. Take a look!'}</p>
          <a href={`/${lang}/search`} class="inline-flex items-center gap-2 bg-tropical-primary text-white font-extrabold px-6 py-3 rounded-2xl hover:bg-tropical-primary/90 transition-colors shadow-lg shadow-tropical-primary/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            {lang === 'es' ? 'Explorar salas' : 'Explore rooms'}
          </a>
        </div>
      )}
    </div>
    <div class="h-16"></div>
  </main>

  <script>
    // Filter logic
    const filterBtns = document.querySelectorAll('.filter-btn');
    const offerCards = document.querySelectorAll('.offer-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => {
          b.classList.remove('active', 'bg-tropical-primary', 'text-white', 'shadow-md');
          b.classList.add('bg-gray-50', 'text-tropical-text/60', 'border', 'border-gray-100');
        });
        btn.classList.add('active', 'bg-tropical-primary', 'text-white', 'shadow-md');
        btn.classList.remove('bg-gray-50', 'text-tropical-text/60', 'border', 'border-gray-100');

        const filter = (btn as HTMLElement).dataset.filter;
        offerCards.forEach((card, idx) => {
          const el = card as HTMLElement;
          if (filter === 'all' || el.dataset.type === filter) {
            el.style.display = '';
            el.style.animation = 'none';
            el.offsetHeight;
            el.style.animation = `slide-up-delay 0.4s ease-out ${idx * 0.05}s forwards`;
          } else {
            el.style.display = 'none';
          }
        });
      });
    });

    // Conditions tooltip
    document.querySelectorAll('.conditions-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const conditions = (btn as HTMLElement).dataset.conditions;
        if (conditions) alert(conditions);
      });
    });
  </script>
</Layout>
