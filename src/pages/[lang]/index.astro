---
// apps/marketplace/src/pages/[lang]/index.astro
export const prerender = false;
import { query } from '../../lib/db';
import '../../styles/global.css';

import { ui } from '../../i18n/ui';
import Layout from '../../layouts/Layout.astro';

import { HeroSearchBar } from '../../components/HeroSearchBar';
import { GameCard } from '../../components/GameCard';
import { NearYouSection } from '../../components/NearYouSection';
import { SocialFeed } from '../../components/react/SocialFeed';
import { ChevronRight } from 'lucide-react';
import { getDefaultRoomImage } from '../../lib/default-room-images';

const { lang = 'es' } = Astro.params;
const t = (key: keyof typeof ui['es']) => (ui[lang as keyof typeof ui] || ui['es'])[key] || key;

let games: any[] = [];
let themes: any[] = [];

try {
    const { rows: gameRows } = await query(
        `SELECT r.id, r.name, r.city, r.province, r.capacity_min, r.capacity,
                r.duration_minutes, r.difficulty_level, r.price_per_person,
                r.description, r.average_rating, r.total_reviews,
                r.latitude, r.longitude, r.themes, r.image_url
         FROM rooms r
         WHERE r.is_active = true
         ORDER BY r.average_rating DESC NULLS LAST, r.created_at DESC
         LIMIT 200`
    );
    
    games = gameRows.map(g => ({
        id: g.id,
        name: g.name,
        city: g.city || 'España',
        province: g.province || '',
        players_min: g.capacity_min || 2,
        players_max: g.capacity || 6,
        duration: g.duration_minutes || 60,
        difficulty: g.difficulty_level ? `Nivel ${g.difficulty_level}` : 'Normal',
        price_min: parseFloat(g.price_per_person) || 0,
        images: g.image_url ? [g.image_url] : [getDefaultRoomImage(g.id)],
        description: g.description,
        rating: parseFloat(g.average_rating) || 0,
        reviews_count: g.total_reviews || 0,
        themes: g.themes || [],
        lat: g.latitude,
        lng: g.longitude,
    }));
} catch (e: any) {
    console.error("[Marketplace] DB Error:", e.message);
}

const featuredGames = games.slice(0, 12);
---

<Layout title="EscapeMaster · Escape Rooms en España">
    <main class="pb-20 sm:pb-0">
        {/* Search section — hero + search bar */}
        <section class="pt-6 sm:pt-10 pb-4 sm:pb-6 px-4 sm:px-6">
            <div class="max-w-4xl mx-auto">
                <div class="text-center mb-5 sm:mb-6">
                    <h1 class="text-2xl sm:text-4xl font-bold text-tropical-text tracking-tight leading-tight">
                        {lang === 'en' ? 'Discover the best Escape Rooms in Spain' : 'Descubre los mejores Escape Rooms de España'}
                    </h1>
                    <p class="text-sm sm:text-base text-tropical-text/60 mt-2">
                        {lang === 'en' ? 'Search, compare and book in minutes' : 'Busca, compara y reserva en minutos'}
                    </p>
                </div>
                <HeroSearchBar
                    client:load
                    translations={{
                        where: t('hero.search.where'),
                        when: t('hero.search.when'),
                        players: t('hero.search.players'),
                        button: t('hero.search.button')
                    }}
                    currentLang={lang}
                    themes={themes}
                />
            </div>
        </section>

        {/* Featured rooms — hidden when no data */}
        {featuredGames.length > 0 && (
        <section class="max-w-7xl mx-auto px-4 sm:px-6 pt-2 sm:pt-4 pb-6 sm:pb-10">
            <div class="flex items-end justify-between mb-4 sm:mb-6">
                <div>
                    <h2 class="text-lg sm:text-[22px] font-semibold text-tropical-text">{t('games.new')}</h2>
                    <p class="text-sm text-tropical-text/50 mt-0.5">{t('games.new.subtitle')}</p>
                </div>
                <a href={`/${lang}/search`} class="hidden sm:flex items-center gap-1 text-sm font-medium text-tropical-primary hover:underline">
                    {t('games.view_all')}
                    <ChevronRight className="w-4 h-4" />
                </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-8">
                {featuredGames.map((game) => (
                    <GameCard game={game} lang={lang} client:visible />
                ))}
            </div>

            <div class="mt-8 text-center sm:hidden">
                <a href={`/${lang}/search`} class="inline-flex items-center gap-1 text-sm font-semibold text-tropical-primary">
                    {t('games.view_all')}
                    <ChevronRight className="w-4 h-4" />
                </a>
            </div>
        </section>
        )}

        {/* Near you — geolocation based */}
        <NearYouSection client:load lang={lang} />

        {/* Social Feed — recent activity */}
        <section class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-10">
            <div class="flex items-end justify-between mb-4 sm:mb-6">
                <div>
                    <h2 class="text-lg sm:text-[22px] font-semibold text-tropical-text">
                        {lang === 'en' ? 'Community Activity' : 'Actividad de la Comunidad'}
                    </h2>
                    <p class="text-sm text-tropical-text/50 mt-0.5">
                        {lang === 'en' ? 'See what other players are doing' : 'Mira lo que hacen otros jugadores'}
                    </p>
                </div>
            </div>
            <SocialFeed client:visible lang={lang} />
        </section>

        {/* CTA — clean, no gradients */}
        <section class="px-4 sm:px-6 py-8 sm:py-12">
            <div class="max-w-4xl mx-auto bg-tropical-primary rounded-2xl sm:rounded-3xl p-8 sm:p-16 text-center">
                <h2 class="text-2xl sm:text-4xl font-bold text-white mb-3">{t('cta.title')}</h2>
                <p class="text-white/70 text-sm sm:text-base mb-6 sm:mb-8 max-w-xl mx-auto">
                    {t('cta.description')}
                </p>
                <a href="https://manager.escapemaster.es" 
                   class="inline-block bg-white text-tropical-primary font-semibold text-sm px-6 py-3 rounded-xl hover:bg-gray-50 transition-colors">
                    {t('cta.button')}
                </a>
            </div>
        </section>
    </main>
</Layout>

