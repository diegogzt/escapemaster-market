---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/db';
import { Mail, Phone, MapPin, Send } from 'lucide-react';

const { lang = 'es' } = Astro.params;

let companyInfo: Record<string, string> = {};
try {
    const { rows } = await query(
        `SELECT key, value FROM platform_settings WHERE key IN ('company_email', 'company_phone', 'company_address', 'company_name')`
    );
    for (const r of rows) companyInfo[r.key] = r.value;
} catch (_) {}

const email = companyInfo['company_email'] || 'info@escapemaster.es';
const phone = companyInfo['company_phone'] || '+34 900 123 456';
const address = companyInfo['company_address'] || 'Calle Principal 123, Madrid';
const companyName = companyInfo['company_name'] || 'EscapeMaster';

const titles = {
    es: 'Contacto',
    en: 'Contact Us'
};

const labels = {
    es: {
        title: 'Contacto',
        subtitle: 'Ponte en contacto con nosotros',
        form_title: 'Envíanos un Mensaje',
        name: 'Nombre',
        email_label: 'Email',
        message: 'Mensaje',
        send: 'Enviar',
        hours: 'Disponibles de lunes a viernes, 9:00 - 18:00'
    },
    en: {
        title: 'Contact Us',
        subtitle: 'Get in touch with us',
        form_title: 'Send us a Message',
        name: 'Name',
        email_label: 'Email',
        message: 'Message',
        send: 'Send',
        hours: 'Available Monday to Friday, 9:00 AM - 6:00 PM'
    }
};

const text = labels[lang as keyof typeof labels] || labels.es;
const title = text.title;
---

<Layout title={title}>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16 lg:py-24">
        <!-- Header Section -->
        <div class="mb-10 sm:mb-16 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-tropical-primary/10 mb-6">
                <Mail className="w-8 h-8 sm:w-10 sm:h-10 text-tropical-primary" />
            </div>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-tropical-primary tracking-tight mb-3 sm:mb-4">{text.title}</h1>
            <p class="text-tropical-text/60 text-base sm:text-lg max-w-xl mx-auto">{text.subtitle}</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 mb-10 sm:mb-16">
            <!-- Contact Info -->
            <div class="space-y-6 sm:space-y-8">
                <div>
                    <h2 class="text-xl sm:text-2xl font-bold text-tropical-primary mb-4 sm:mb-6">
                        {lang === 'en' ? 'Contact Information' : 'Información de Contacto'}
                    </h2>
                </div>

                <div class="flex gap-4">
                    <div class="w-11 h-11 sm:w-12 sm:h-12 rounded-xl bg-tropical-primary/10 flex items-center justify-center shrink-0">
                        <Mail className="w-5 h-5 sm:w-6 sm:h-6 text-tropical-primary" />
                    </div>
                    <div class="flex-1 min-w-0">
                        <h3 class="font-bold text-tropical-primary mb-1">Email</h3>
                        <a href={`mailto:${email}`} class="text-tropical-primary font-semibold hover:underline break-all">
                            {email}
                        </a>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div class="w-11 h-11 sm:w-12 sm:h-12 rounded-xl bg-tropical-primary/10 flex items-center justify-center shrink-0">
                        <Phone className="w-5 h-5 sm:w-6 sm:h-6 text-tropical-primary" />
                    </div>
                    <div class="flex-1">
                        <h3 class="font-bold text-tropical-primary mb-1">
                            {lang === 'en' ? 'Phone' : 'Teléfono'}
                        </h3>
                        <a href={`tel:${phone.replace(/\s/g, '')}`} class="text-tropical-primary font-semibold hover:underline">
                            {phone}
                        </a>
                        <p class="text-xs sm:text-sm text-tropical-text/60 mt-1">{text.hours}</p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div class="w-11 h-11 sm:w-12 sm:h-12 rounded-xl bg-tropical-primary/10 flex items-center justify-center shrink-0">
                        <MapPin className="w-5 h-5 sm:w-6 sm:h-6 text-tropical-primary" />
                    </div>
                    <div class="flex-1">
                        <h3 class="font-bold text-tropical-primary mb-1">
                            {lang === 'en' ? 'Address' : 'Dirección'}
                        </h3>
                        <p class="text-tropical-text/70 text-sm sm:text-base">{address}</p>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 border border-tropical-secondary/10 shadow-sm">
                <h3 class="text-lg sm:text-xl font-bold text-tropical-primary mb-6">{text.form_title}</h3>
                <form class="space-y-4 sm:space-y-5">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-tropical-text/50 mb-2 ml-1">
                            {text.name}
                        </label>
                        <input
                            type="text"
                            required
                            class="w-full h-11 sm:h-12 px-4 rounded-xl border border-tropical-secondary/20 bg-white text-base focus:outline-none focus:ring-2 focus:ring-tropical-primary/20 focus:border-tropical-primary transition-all shadow-sm"
                            placeholder={lang === 'en' ? 'Your name' : 'Tu nombre'}
                        />
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-tropical-text/50 mb-2 ml-1">
                            {text.email_label}
                        </label>
                        <input
                            type="email"
                            required
                            class="w-full h-11 sm:h-12 px-4 rounded-xl border border-tropical-secondary/20 bg-white text-base focus:outline-none focus:ring-2 focus:ring-tropical-primary/20 focus:border-tropical-primary transition-all shadow-sm"
                            placeholder="tu@email.com"
                        />
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-tropical-text/50 mb-2 ml-1">
                            {text.message}
                        </label>
                        <textarea
                            required
                            rows={5}
                            class="w-full px-4 py-3 rounded-xl border border-tropical-secondary/20 bg-white text-base focus:outline-none focus:ring-2 focus:ring-tropical-primary/20 focus:border-tropical-primary transition-all resize-none shadow-sm"
                            placeholder={lang === 'en' ? 'Your message...' : 'Tu mensaje...'}
                        ></textarea>
                    </div>
                    <button
                        type="submit"
                        class="w-full h-12 sm:h-11 bg-tropical-primary text-white font-bold rounded-xl hover:bg-tropical-primary/90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 shadow-lg shadow-tropical-primary/20 touch-manipulation"
                    >
                        <Send className="w-4 h-4" />
                        {text.send}
                    </button>
                </form>
            </div>
        </div>

        <!-- Bottom CTA -->
        <div class="p-6 sm:p-8 rounded-2xl bg-gradient-to-r from-tropical-primary/5 to-tropical-secondary/5 border border-tropical-primary/20 text-center">
            <p class="text-tropical-text/70 text-sm sm:text-base">
                {lang === 'en' 
                    ? `We'll respond to your message as soon as possible. Thank you for contacting ${companyName}.` 
                    : `Responderemos a tu mensaje lo antes posible. Gracias por contactar con ${companyName}.`
                }
            </p>
        </div>
    </div>
</Layout>
