---
import Layout from '../../../layouts/Layout.astro';
import { Button } from '../../../components/ui/Button';

const { lang } = Astro.params;

const t = lang === 'en' ? {
  title: 'Edit Profile',
  subtitle: 'Update your personal information',
  personalInfo: 'Personal Information',
  name: 'Full Name',
  email: 'Email',
  phone: 'Phone',
  birthday: 'Birthday',
  gender: 'Gender',
  genderOptions: { male: 'Male', female: 'Female', other: 'Other', prefer_not: 'Prefer not to say' },
  avatar: 'Profile Photo',
  changePhoto: 'Change Photo',
  preferences: 'Preferences',
  language: 'Language',
  currency: 'Currency',
  save: 'Save Changes',
  cancel: 'Cancel',
  success: 'Profile updated successfully',
  error: 'Error updating profile'
} : {
  title: 'Editar Perfil',
  subtitle: 'Actualiza tu información personal',
  personalInfo: 'Información Personal',
  name: 'Nombre Completo',
  email: 'Correo electrónico',
  phone: 'Teléfono',
  birthday: 'Fecha de nacimiento',
  gender: 'Género',
  genderOptions: { male: 'Masculino', female: 'Femenino', other: 'Otro', prefer_not: 'Prefiero no decir' },
  avatar: 'Foto de Perfil',
  changePhoto: 'Cambiar Foto',
  preferences: 'Preferencias',
  language: 'Idioma',
  currency: 'Moneda',
  save: 'Guardar Cambios',
  cancel: 'Cancelar',
  success: 'Perfil actualizado correctamente',
  error: 'Error al actualizar el perfil'
};
---

<Layout title={`${t.title} | EscapeMaster`}>
  <main class="min-h-screen pt-16 sm:pt-20 pb-24 sm:pb-20 bg-tropical-bg">
    <div class="max-container px-4">
      <div class="max-w-2xl mx-auto">
        <!-- Header -->
        <div class="mb-6 sm:mb-8">
          <a href={`/${lang}/profile`} class="text-tropical-secondary hover:underline flex items-center gap-1 text-sm mb-3 sm:mb-4 touch-manipulation">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            {lang === 'en' ? 'Back to Profile' : 'Volver al Perfil'}
          </a>
          <h1 class="text-2xl sm:text-3xl font-bold text-tropical-text">{t.title}</h1>
          <p class="text-tropical-text/50 mt-1 sm:mt-2 text-sm sm:text-base">{t.subtitle}</p>
        </div>

        <!-- Loading State -->
        <div id="loadingState" class="flex items-center justify-center py-40">
          <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-tropical-text"></div>
        </div>

        <!-- Form -->
        <form id="editProfileForm" class="hidden space-y-8">
          <!-- Avatar Section -->
          <div class="bg-white rounded-2xl shadow-lg border border-tropical-card p-6">
            <h2 class="text-lg font-semibold text-tropical-text mb-4">{t.avatar}</h2>
            <div class="flex items-center gap-6">
              <div class="relative">
                <div id="avatarPreview" class="w-24 h-24 bg-tropical-secondary rounded-full flex items-center justify-center text-white text-3xl font-bold overflow-hidden">
                  <span id="initials">U</span>
                </div>
                <button type="button" id="avatarBtn" class="absolute -bottom-1 -right-1 bg-white border border-gray-200 rounded-full p-2 shadow hover:shadow-md transition-shadow">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
                </button>
                <input type="file" id="avatarInput" accept="image/*" class="hidden" />
              </div>
              <div>
                <p class="text-sm text-tropical-text/50">{t.changePhoto}</p>
                <p class="text-xs text-gray-400 mt-1">JPG, PNG. Max 5MB</p>
              </div>
            </div>
          </div>

          <!-- Personal Info Section -->
          <div class="bg-white rounded-2xl shadow-lg border border-tropical-card p-6">
            <h2 class="text-lg font-semibold text-tropical-text mb-6">{t.personalInfo}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="md:col-span-2">
                <label for="fullName" class="block text-sm font-medium text-tropical-text mb-1">{t.name}</label>
                <input
                  type="text"
                  id="fullName"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-tropical-secondary focus:border-transparent transition-all outline-none"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-tropical-text mb-1">{t.email}</label>
                <input
                  type="email"
                  id="email"
                  disabled
                  class="w-full px-4 py-3 rounded-xl border border-gray-100 bg-tropical-bg text-tropical-text/50 cursor-not-allowed"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-tropical-text mb-1">{t.phone}</label>
                <input
                  type="tel"
                  id="phone"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-tropical-secondary focus:border-transparent transition-all outline-none"
                  placeholder="+34 600 000 000"
                />
              </div>
              <div>
                <label for="birthday" class="block text-sm font-medium text-tropical-text mb-1">{t.birthday}</label>
                <input
                  type="date"
                  id="birthday"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-tropical-secondary focus:border-transparent transition-all outline-none"
                />
              </div>
              <div>
                <label for="gender" class="block text-sm font-medium text-tropical-text mb-1">{t.gender}</label>
                <select
                  id="gender"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-tropical-secondary focus:border-transparent transition-all outline-none bg-white"
                >
                  <option value="">--</option>
                  <option value="male">{t.genderOptions.male}</option>
                  <option value="female">{t.genderOptions.female}</option>
                  <option value="other">{t.genderOptions.other}</option>
                  <option value="prefer_not">{t.genderOptions.prefer_not}</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Preferences Section -->
          <div class="bg-white rounded-2xl shadow-lg border border-tropical-card p-6">
            <h2 class="text-lg font-semibold text-tropical-text mb-6">{t.preferences}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="language" class="block text-sm font-medium text-tropical-text mb-1">{t.language}</label>
                <select
                  id="language"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-tropical-secondary focus:border-transparent transition-all outline-none bg-white"
                >
                  <option value="es">Español</option>
                  <option value="en">English</option>
                </select>
              </div>
              <div>
                <label for="currency" class="block text-sm font-medium text-tropical-text mb-1">{t.currency}</label>
                <select
                  id="currency"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-tropical-secondary focus:border-transparent transition-all outline-none bg-white"
                >
                  <option value="EUR">EUR (€)</option>
                  <option value="USD">USD ($)</option>
                  <option value="GBP">GBP (£)</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Success/Error Messages -->
          <div id="successMsg" class="hidden text-green-600 text-sm bg-green-50 p-4 rounded-xl border border-green-100">
            {t.success}
          </div>
          <div id="errorMsg" class="hidden text-red-500 text-sm bg-red-50 p-4 rounded-xl border border-red-100">
            {t.error}
          </div>

          <!-- Actions -->
          <div class="flex gap-4 justify-end">
            <a href={`/${lang}/profile`}>
              <Button type="button" variant="ghost">{t.cancel}</Button>
            </a>
            <Button type="submit">{t.save}</Button>
          </div>
        </form>
      </div>
    </div>
  </main>
</Layout>


<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL || "http://localhost:8000/v1/api";
  import { auth } from '../../../lib/auth';

  async function initEditProfile() {
    const session = await auth.getSession();
    
    if (!session.user) {
      const lang = window.location.pathname.split('/')[1] || 'es';
      window.location.href = `/${lang}/login`;
      return;
    }

    const { user } = session;

    // Hide loading, show form
    document.getElementById('loadingState')?.classList.add('hidden');
    document.getElementById('editProfileForm')?.classList.remove('hidden');
    
    // Populate fields
    const fullNameEl = document.getElementById('fullName') as HTMLInputElement;
    const emailEl = document.getElementById('email') as HTMLInputElement;
    const initialsEl = document.getElementById('initials');

    if (fullNameEl) fullNameEl.value = user.full_name || '';
    if (emailEl) emailEl.value = user.email || '';
    if (initialsEl) initialsEl.textContent = (user.full_name || 'U').charAt(0).toUpperCase();

    // Avatar change
    const avatarBtn = document.getElementById('avatarBtn');
    const avatarInput = document.getElementById('avatarInput') as HTMLInputElement;
    const avatarPreview = document.getElementById('avatarPreview');

    avatarBtn?.addEventListener('click', () => avatarInput?.click());
    avatarInput?.addEventListener('change', (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (file && avatarPreview) {
        const reader = new FileReader();
        reader.onload = (e) => {
          avatarPreview.innerHTML = `<img src="${e.target?.result}" class="w-full h-full object-cover" />`;
        };
        reader.readAsDataURL(file);
      }
    });

    // Form submit
    const form = document.getElementById('editProfileForm') as HTMLFormElement;
    const successMsg = document.getElementById('successMsg');
    const errorMsg = document.getElementById('errorMsg');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      successMsg?.classList.add('hidden');
      errorMsg?.classList.add('hidden');

      const fullName = (document.getElementById('fullName') as HTMLInputElement).value;
      const phone = (document.getElementById('phone') as HTMLInputElement).value;
      const birthday = (document.getElementById('birthday') as HTMLInputElement).value;
      const gender = (document.getElementById('gender') as HTMLSelectElement).value;
      const language = (document.getElementById('language') as HTMLSelectElement).value;
      const currency = (document.getElementById('currency') as HTMLSelectElement).value;

      try {
        const token = localStorage.getItem('em_token');
        const response = await fetch(`${API_BASE}/players/me`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({
            full_name: fullName,
            phone,
            birthday: birthday || null,
            gender: gender || null,
            preferred_language: language,
            preferred_currency: currency
          })
        });

        if (!response.ok) throw new Error('Error al actualizar');

        // Update local storage
        const updatedUser = { ...user, full_name: fullName };
        localStorage.setItem('em_user', JSON.stringify(updatedUser));

        successMsg?.classList.remove('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } catch (err: any) {
        errorMsg?.classList.remove('hidden');
      }
    });
  }

  initEditProfile();
</script>
