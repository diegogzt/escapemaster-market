---
import Layout from '../../../layouts/Layout.astro';
import { Button } from '../../../components/ui/Button';

const { lang } = Astro.params;

const t = lang === 'en' ? {
  title: 'Settings',
  subtitle: 'Manage your account preferences',
  notifications: 'Notifications',
  notificationsDesc: 'Configure how you want to receive updates',
  emailNotifs: 'Email notifications',
  emailNotifsDesc: 'Receive booking confirmations and reminders by email',
  pushNotifs: 'Push notifications',
  pushNotifsDesc: 'Receive instant notifications on your device',
  marketingNotifs: 'Marketing emails',
  marketingNotifsDesc: 'Receive offers, promotions and news',
  privacy: 'Privacy',
  privacyDesc: 'Control your data and visibility',
  profilePublic: 'Public profile',
  profilePublicDesc: 'Allow others to see your achievements and reviews',
  showStats: 'Show statistics',
  showStatsDesc: 'Display your escape rate and number of games',
  security: 'Security',
  securityDesc: 'Protect your account',
  changePassword: 'Change password',
  twoFactor: 'Two-factor authentication',
  twoFactorDesc: 'Add an extra layer of security to your account',
  dangerZone: 'Danger Zone',
  deleteAccount: 'Delete Account',
  deleteAccountDesc: 'Permanently delete your account and all data',
  save: 'Save Changes',
  saved: 'Changes saved successfully'
} : {
  title: 'Ajustes',
  subtitle: 'Gestiona las preferencias de tu cuenta',
  notifications: 'Notificaciones',
  notificationsDesc: 'Configura cómo quieres recibir actualizaciones',
  emailNotifs: 'Notificaciones por email',
  emailNotifsDesc: 'Recibe confirmaciones de reserva y recordatorios por email',
  pushNotifs: 'Notificaciones push',
  pushNotifsDesc: 'Recibe notificaciones instantáneas en tu dispositivo',
  marketingNotifs: 'Emails de marketing',
  marketingNotifsDesc: 'Recibe ofertas, promociones y novedades',
  privacy: 'Privacidad',
  privacyDesc: 'Controla tus datos y visibilidad',
  profilePublic: 'Perfil público',
  profilePublicDesc: 'Permite que otros vean tus logros y reseñas',
  showStats: 'Mostrar estadísticas',
  showStatsDesc: 'Muestra tu tasa de escape y número de partidas',
  security: 'Seguridad',
  securityDesc: 'Protege tu cuenta',
  changePassword: 'Cambiar contraseña',
  twoFactor: 'Autenticación de dos factores',
  twoFactorDesc: 'Añade una capa extra de seguridad a tu cuenta',
  dangerZone: 'Zona de Peligro',
  deleteAccount: 'Eliminar Cuenta',
  deleteAccountDesc: 'Elimina permanentemente tu cuenta y todos tus datos',
  save: 'Guardar Cambios',
  saved: 'Cambios guardados correctamente'
};
---

<Layout title={`${t.title} | EscapeMaster`}>
  <main class="min-h-screen pt-20 sm:pt-32 pb-24 sm:pb-20 bg-tropical-bg">
    <div class="max-container px-4">
      <div class="max-w-2xl mx-auto">
        <!-- Header -->
        <div class="mb-6 sm:mb-8">
          <a href={`/${lang}/profile`} class="text-tropical-secondary hover:underline flex items-center gap-1 text-sm mb-3 sm:mb-4 touch-manipulation">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            {lang === 'en' ? 'Back to Profile' : 'Volver al Perfil'}
          </a>
          <h1 class="text-xl sm:text-2xl font-bold text-tropical-primary">{t.title}</h1>
          <p class="text-gray-500 mt-1 sm:mt-2 text-sm sm:text-base">{t.subtitle}</p>
        </div>

        <!-- Loading -->
        <div id="loadingState" class="flex items-center justify-center py-40">
          <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-tropical-text"></div>
        </div>

        <!-- Settings Content -->
        <div id="settingsContent" class="hidden space-y-6">
          <!-- Notifications Section -->
          <div class="bg-white rounded-2xl shadow-lg border border-tropical-card p-6">
            <div class="flex items-center gap-3 mb-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-tropical-text" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
              <h2 class="text-lg font-semibold text-tropical-text">{t.notifications}</h2>
            </div>
            <p class="text-sm text-gray-500 mb-6">{t.notificationsDesc}</p>
            
            <div class="space-y-4">
              <label class="flex items-center justify-between p-4 bg-gray-50 rounded-xl cursor-pointer hover:bg-gray-100 transition-colors">
                <div>
                  <p class="font-medium text-gray-800">{t.emailNotifs}</p>
                  <p class="text-sm text-gray-500">{t.emailNotifsDesc}</p>
                </div>
                <input type="checkbox" id="emailNotifs" checked class="toggle-switch" />
              </label>
              
              <label class="flex items-center justify-between p-4 bg-gray-50 rounded-xl cursor-pointer hover:bg-gray-100 transition-colors">
                <div>
                  <p class="font-medium text-gray-800">{t.pushNotifs}</p>
                  <p class="text-sm text-gray-500">{t.pushNotifsDesc}</p>
                </div>
                <input type="checkbox" id="pushNotifs" checked class="toggle-switch" />
              </label>
              
              <label class="flex items-center justify-between p-4 bg-gray-50 rounded-xl cursor-pointer hover:bg-gray-100 transition-colors">
                <div>
                  <p class="font-medium text-gray-800">{t.marketingNotifs}</p>
                  <p class="text-sm text-gray-500">{t.marketingNotifsDesc}</p>
                </div>
                <input type="checkbox" id="marketingNotifs" class="toggle-switch" />
              </label>
            </div>
          </div>

          <!-- Privacy Section -->
          <div class="bg-white rounded-2xl shadow-lg border border-tropical-card p-6">
            <div class="flex items-center gap-3 mb-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-tropical-text" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
              <h2 class="text-lg font-semibold text-tropical-text">{t.privacy}</h2>
            </div>
            <p class="text-sm text-gray-500 mb-6">{t.privacyDesc}</p>
            
            <div class="space-y-4">
              <label class="flex items-center justify-between p-4 bg-gray-50 rounded-xl cursor-pointer hover:bg-gray-100 transition-colors">
                <div>
                  <p class="font-medium text-gray-800">{t.profilePublic}</p>
                  <p class="text-sm text-gray-500">{t.profilePublicDesc}</p>
                </div>
                <input type="checkbox" id="profilePublic" checked class="toggle-switch" />
              </label>
              
              <label class="flex items-center justify-between p-4 bg-gray-50 rounded-xl cursor-pointer hover:bg-gray-100 transition-colors">
                <div>
                  <p class="font-medium text-gray-800">{t.showStats}</p>
                  <p class="text-sm text-gray-500">{t.showStatsDesc}</p>
                </div>
                <input type="checkbox" id="showStats" checked class="toggle-switch" />
              </label>
            </div>
          </div>

          <!-- Security Section -->
          <div class="bg-white rounded-2xl shadow-lg border border-tropical-card p-6">
            <div class="flex items-center gap-3 mb-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-tropical-text" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <h2 class="text-lg font-semibold text-tropical-text">{t.security}</h2>
            </div>
            <p class="text-sm text-gray-500 mb-6">{t.securityDesc}</p>
            
            <div class="space-y-4">
              <a href={`/${lang}/profile/change-password`} class="flex items-center justify-between p-4 bg-gray-50 rounded-xl cursor-pointer hover:bg-gray-100 transition-colors">
                <div>
                  <p class="font-medium text-gray-800">{t.changePassword}</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><path d="m9 18 6-6-6-6"/></svg>
              </a>
              
              <label class="flex items-center justify-between p-4 bg-gray-50 rounded-xl cursor-pointer hover:bg-gray-100 transition-colors">
                <div>
                  <p class="font-medium text-gray-800">{t.twoFactor}</p>
                  <p class="text-sm text-gray-500">{t.twoFactorDesc}</p>
                </div>
                <input type="checkbox" id="twoFactor" class="toggle-switch" />
              </label>
            </div>
          </div>

          <!-- Danger Zone -->
          <div class="bg-white rounded-2xl shadow-lg border border-red-200 p-6">
            <div class="flex items-center gap-3 mb-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
              <h2 class="text-lg font-semibold text-red-600">{t.dangerZone}</h2>
            </div>
            
            <div class="mt-4">
              <button id="deleteAccountBtn" class="flex items-center justify-between w-full p-4 bg-red-50 rounded-xl cursor-pointer hover:bg-red-100 transition-colors text-left">
                <div>
                  <p class="font-medium text-red-600">{t.deleteAccount}</p>
                  <p class="text-sm text-red-400">{t.deleteAccountDesc}</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-400"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
              </button>
            </div>
          </div>

          <!-- Save Button -->
          <div class="flex justify-end">
            <Button id="saveBtn" type="button">{t.save}</Button>
          </div>

          <!-- Success Message -->
          <div id="successMsg" class="hidden text-green-600 text-sm bg-green-50 p-4 rounded-xl border border-green-100 text-center">
            {t.saved}
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .toggle-switch {
    position: relative;
    width: 2.75rem;
    height: 1.5rem;
    background-color: #d1d5db;
    border-radius: 9999px;
    cursor: pointer;
    appearance: none;
    transition: background-color 0.15s ease;
  }
  .toggle-switch:checked {
    background-color: var(--color-tropical-secondary);
  }
  .toggle-switch::before {
    content: '';
    position: absolute;
    top: 0.125rem;
    left: 0.125rem;
    width: 1.25rem;
    height: 1.25rem;
    background-color: white;
    border-radius: 9999px;
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
    transition: transform 0.15s ease;
  }
  .toggle-switch:checked::before {
    transform: translateX(1.25rem);
  }
</style>

<script>
  import { auth } from '../../../lib/auth';

  async function initSettings() {
    const session = await auth.getSession();
    
    if (!session.user) {
      const lang = window.location.pathname.split('/')[1] || 'es';
      window.location.href = `/${lang}/login`;
      return;
    }

    // Hide loading, show content
    document.getElementById('loadingState')?.classList.add('hidden');
    document.getElementById('settingsContent')?.classList.remove('hidden');

    try {
      const token = localStorage.getItem('em_token');
      const response = await fetch('/api/players/me/settings', {
        headers: { 'Authorization': `Bearer ${token}` }
      });

      if (response.ok) {
        const data = await response.json();
        (document.getElementById('emailNotifs') as HTMLInputElement).checked = !!data.email_notifications;
        (document.getElementById('pushNotifs') as HTMLInputElement).checked = !!data.push_notifications;
        (document.getElementById('marketingNotifs') as HTMLInputElement).checked = !!(data.marketing_notifications ?? data.marketing_emails);
        (document.getElementById('profilePublic') as HTMLInputElement).checked = !!data.profile_public;
        (document.getElementById('showStats') as HTMLInputElement).checked = !!data.show_stats;
      }
    } catch (err) {
      console.error('Error loading settings:', err);
    }

    // Save button
    document.getElementById('saveBtn')?.addEventListener('click', async () => {
      const settings = {
        email_notifications: (document.getElementById('emailNotifs') as HTMLInputElement).checked,
        push_notifications: (document.getElementById('pushNotifs') as HTMLInputElement).checked,
        marketing_notifications: (document.getElementById('marketingNotifs') as HTMLInputElement).checked,
        profile_public: (document.getElementById('profilePublic') as HTMLInputElement).checked,
        show_stats: (document.getElementById('showStats') as HTMLInputElement).checked,
        two_factor_enabled: (document.getElementById('twoFactor') as HTMLInputElement).checked,
      };

      try {
        const token = localStorage.getItem('em_token');
        await fetch('/api/players/me/settings', {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(settings)
        });

        const successMsg = document.getElementById('successMsg');
        successMsg?.classList.remove('hidden');
        setTimeout(() => successMsg?.classList.add('hidden'), 3000);
      } catch (err) {
        console.error('Error saving settings:', err);
      }
    });

    // Delete account button
    document.getElementById('deleteAccountBtn')?.addEventListener('click', () => {
      const lang = window.location.pathname.split('/')[1] || 'es';
      const confirmMsg = lang === 'en' 
        ? 'Are you sure you want to delete your account? This action cannot be undone.'
        : '¿Estás seguro de que quieres eliminar tu cuenta? Esta acción no se puede deshacer.';
      
      if (confirm(confirmMsg)) {
        // Would call delete endpoint here
        auth.logout();
      }
    });
  }

  initSettings();
</script>
