---
import Layout from '../../../layouts/Layout.astro';

const { lang: langParam } = Astro.params;
const lang = langParam || 'es';
---

<Layout title={`${lang === 'en' ? 'My Rooms' : 'Mis Salas'} | EscapeMaster`}>
  <main class="min-h-screen pb-24 sm:pb-20 bg-tropical-bg">
    <div class="max-container px-3 sm:px-4 py-6 sm:py-8">
      <!-- Header -->
      <div class="flex items-center gap-3 mb-6">
        <a href={`/${lang}/profile`} class="p-2 -ml-2 rounded-lg hover:bg-tropical-card/60 transition-colors text-tropical-text/60 hover:text-tropical-text">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div>
          <h1 class="text-xl sm:text-2xl font-black text-tropical-primary">
            {lang === 'en' ? 'My Rooms' : 'Mis Salas'}
          </h1>
          <p class="text-sm text-tropical-text/60">
            {lang === 'en' ? 'Manage your escape rooms' : 'Gestiona tus salas de escape'}
          </p>
        </div>
      </div>

      <!-- React Island -->
      <div id="enterprise-rooms"></div>
    </div>
  </main>
</Layout>

<script>
  import React from 'react';
  import { createRoot } from 'react-dom/client';
  import { EnterpriseRooms } from '../../../components/react/EnterpriseRooms';

  const container = document.getElementById('enterprise-rooms');
  if (container) {
    const lang = document.documentElement.lang || 'es';
    const root = createRoot(container);
    root.render(React.createElement(EnterpriseRooms, { lang }));
  }
</script>
