---
import Layout from '../../layouts/Layout.astro';
import { RegisterForm } from '../../components/react/RegisterForm';

const { lang = 'es' } = Astro.params;
---

<Layout title="Crear Cuenta | EscapeMaster" hideFooter>
  <main class="min-h-[calc(100vh-6rem)] pt-16 sm:pt-20 py-8 sm:py-12 bg-tropical-bg flex items-center justify-center">
    <div class="w-full max-w-lg mx-auto px-4 sm:px-0 relative">
      <RegisterForm client:load lang={lang} />
    </div>
  </main>
</Layout>
