---
import Layout from '../../layouts/Layout.astro';
import { RegisterForm } from '../../components/react/RegisterForm';

const { lang = 'es' } = Astro.params;
---

<Layout title="Crear Cuenta | EscapeMaster">
  <main class="min-h-screen pt-24 sm:pt-32 pb-24 sm:pb-20 bg-[#FBF9F1] flex items-start sm:items-center justify-center">
    <div class="w-full max-w-lg mx-auto px-4 sm:px-0 relative">
      <RegisterForm client:load lang={lang} />
    </div>
  </main>
</Layout>
