---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { pool } from '../../../lib/db';
import { ui } from '../../../i18n/ui';

const { lang = 'es', id } = Astro.params;
const t = ui[lang as keyof typeof ui] || ui.es;

if (!id) return Astro.redirect(`/${lang}`);

let player: any = null;
let squads: any[] = [];
let recentGames: any[] = [];
let routes: any[] = [];

try {
  // Get player profile
  const playerResult = await pool.query(`
    SELECT p.*, u.full_name, u.email, u.created_at as member_since
    FROM players p
    JOIN users u ON u.id = p.user_id
    WHERE p.id = $1 OR p.user_id = $1
    LIMIT 1
  `, [id]);

  if (playerResult.rows.length > 0) {
    player = playerResult.rows[0];

    // Get squads
    const squadsResult = await pool.query(`
      SELECT s.id, s.name, s.slug, s.avatar_url, s.total_games, s.is_public,
             sm.role, COUNT(sm2.id) as member_count
      FROM squad_members sm
      JOIN squads s ON s.id = sm.squad_id
      LEFT JOIN squad_members sm2 ON sm2.squad_id = s.id AND sm2.status = 'active'
      WHERE sm.player_id = $1 AND sm.status = 'active'
      GROUP BY s.id, sm.role
      ORDER BY s.total_games DESC
    `, [player.id]);
    squads = squadsResult.rows;

    // Get recent bookings/games
    const gamesResult = await pool.query(`
      SELECT b.id, b.start_time, b.num_people, r.name as room_name, r.city,
             r.image_url, r.difficulty_level
      FROM bookings b
      JOIN rooms r ON r.id = b.room_id
      WHERE b.guest_id = $1 AND b.booking_status = 'completed'
      ORDER BY b.start_time DESC
      LIMIT 6
    `, [player.user_id]);
    recentGames = gamesResult.rows;

    // Get user routes
    const routesResult = await pool.query(`
      SELECT ur.id, ur.status, ur.mode, cc.title, cc.slug,
             (SELECT COUNT(*) FROM user_route_rooms WHERE user_route_id = ur.id) as total_rooms,
             (SELECT COUNT(*) FROM user_route_rooms WHERE user_route_id = ur.id AND completed = true) as completed_rooms
      FROM user_routes ur
      JOIN curated_collections cc ON cc.id = ur.collection_id
      WHERE ur.user_id = $1
      ORDER BY ur.created_at DESC
      LIMIT 5
    `, [player.user_id]);
    routes = routesResult.rows;
  }
} catch (e: any) {
  console.error('[Player Profile] Error:', e.message);
}

if (!player) return Astro.redirect(`/${lang}`);

const rankColors: Record<string, string> = {
  'Novato': 'bg-gray-100 text-gray-700',
  'Explorador': 'bg-blue-100 text-blue-700',
  'Veterano': 'bg-purple-100 text-purple-700',
  'Maestro': 'bg-amber-100 text-amber-700',
  'Leyenda': 'bg-tropical-primary/10 text-tropical-primary',
};

const initials = (player.full_name || player.name || '?')
  .split(' ')
  .map((n: string) => n[0])
  .join('')
  .substring(0, 2)
  .toUpperCase();

const memberSince = player.member_since
  ? new Date(player.member_since).toLocaleDateString(lang === 'en' ? 'en-US' : 'es-ES', { year: 'numeric', month: 'long' })
  : '';
---

<Layout title={`${player.full_name || player.name} | EscapeMaster`}>
  <main class="pb-20 sm:pb-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">

      <!-- Profile Header -->
      <div class="bg-white rounded-2xl border border-gray-200 p-6 sm:p-8 mb-6">
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
          <!-- Avatar -->
          <div class="w-24 h-24 rounded-full bg-tropical-primary flex items-center justify-center text-white text-3xl font-bold shadow-lg">
            {initials}
          </div>

          <div class="flex-1 text-center sm:text-left">
            <h1 class="text-2xl font-black text-tropical-text">{player.full_name || player.name}</h1>
            <div class="flex flex-wrap items-center justify-center sm:justify-start gap-2 mt-2">
              <span class={`px-3 py-1 rounded-full text-xs font-bold ${rankColors[player.rank] || 'bg-gray-100 text-gray-700'}`}>
                {player.rank || 'Novato'}
              </span>
              <span class="text-sm text-gray-500">{player.xp || 0} XP</span>
              <span class="text-gray-300">·</span>
              <span class="text-sm text-gray-500">{player.games_played || 0} {lang === 'en' ? 'games' : 'partidas'}</span>
            </div>
            {memberSince && (
              <p class="text-xs text-gray-400 mt-2">
                {lang === 'en' ? 'Member since' : 'Miembro desde'} {memberSince}
              </p>
            )}

            <!-- Action buttons -->
            <div class="flex flex-wrap gap-3 mt-4 justify-center sm:justify-start">
              <a
                href={`/${lang}/chat`}
                class="px-5 py-2.5 bg-tropical-primary text-white text-sm font-bold rounded-xl hover:bg-tropical-primary/90 transition-colors"
                data-send-message-to={player.user_id}
              >
                {lang === 'en' ? 'Send Message' : 'Enviar Mensaje'}
              </a>
            </div>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-4 text-center">
            <div class="bg-gray-50 rounded-xl p-3">
              <p class="text-xl font-black text-tropical-primary">{player.games_played || 0}</p>
              <p class="text-[10px] font-semibold text-gray-500 uppercase">{lang === 'en' ? 'Games' : 'Juegos'}</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-3">
              <p class="text-xl font-black text-tropical-primary">{squads.length}</p>
              <p class="text-[10px] font-semibold text-gray-500 uppercase">{lang === 'en' ? 'Teams' : 'Equipos'}</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-3">
              <p class="text-xl font-black text-tropical-primary">{routes.length}</p>
              <p class="text-[10px] font-semibold text-gray-500 uppercase">{lang === 'en' ? 'Routes' : 'Rutas'}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left column: Teams & Routes -->
        <div class="lg:col-span-2 space-y-6">

          <!-- Squads -->
          {squads.length > 0 && (
            <div class="bg-white rounded-2xl border border-gray-200 p-6">
              <h2 class="font-bold text-lg text-tropical-text mb-4">
                {lang === 'en' ? 'Teams' : 'Equipos'}
              </h2>
              <div class="space-y-3">
                {squads.map((squad) => (
                  <a href={`/${lang}/teams/${squad.id}`} class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors">
                    <div class="w-10 h-10 rounded-full bg-tropical-primary/10 flex items-center justify-center text-tropical-primary font-bold text-sm">
                      {squad.name.substring(0, 2).toUpperCase()}
                    </div>
                    <div class="flex-1">
                      <p class="font-semibold text-sm text-tropical-text">{squad.name}</p>
                      <p class="text-xs text-gray-400">
                        {squad.member_count} {lang === 'en' ? 'members' : 'miembros'}
                        {squad.role === 'leader' && (
                          <span class="ml-1 text-tropical-primary font-semibold">{lang === 'en' ? '· Leader' : '· Lider'}</span>
                        )}
                      </p>
                    </div>
                    <span class="text-xs text-gray-400">{squad.total_games || 0} {lang === 'en' ? 'games' : 'juegos'}</span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Recent Games -->
          {recentGames.length > 0 && (
            <div class="bg-white rounded-2xl border border-gray-200 p-6">
              <h2 class="font-bold text-lg text-tropical-text mb-4">
                {lang === 'en' ? 'Recent Games' : 'Partidas Recientes'}
              </h2>
              <div class="space-y-3">
                {recentGames.map((game) => (
                  <a href={`/${lang}/game/${game.id}`} class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors">
                    {game.image_url ? (
                      <img src={game.image_url} alt={game.room_name} class="w-12 h-12 rounded-lg object-cover" />
                    ) : (
                      <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center text-gray-400">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/></svg>
                      </div>
                    )}
                    <div class="flex-1">
                      <p class="font-semibold text-sm text-tropical-text">{game.room_name}</p>
                      <p class="text-xs text-gray-400">{game.city} · {game.num_people} {lang === 'en' ? 'players' : 'jugadores'}</p>
                    </div>
                    <span class="text-xs text-gray-400">
                      {new Date(game.start_time).toLocaleDateString(lang === 'en' ? 'en-US' : 'es-ES', { day: 'numeric', month: 'short' })}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Right column: Routes -->
        <div class="space-y-6">
          {routes.length > 0 && (
            <div class="bg-white rounded-2xl border border-gray-200 p-6">
              <h2 class="font-bold text-lg text-tropical-text mb-4">
                {lang === 'en' ? 'Routes' : 'Rutas'}
              </h2>
              <div class="space-y-3">
                {routes.map((route) => {
                  const progress = route.total_rooms > 0
                    ? Math.round((route.completed_rooms / route.total_rooms) * 100)
                    : 0;
                  return (
                    <div class="p-3 rounded-xl bg-gray-50">
                      <p class="font-semibold text-sm text-tropical-text">{route.title}</p>
                      <div class="flex items-center gap-2 mt-2">
                        <div class="flex-1 h-2 bg-gray-200 rounded-full overflow-hidden">
                          <div class="h-full bg-tropical-primary rounded-full transition-all" style={`width: ${progress}%`}></div>
                        </div>
                        <span class="text-xs font-semibold text-gray-500">{progress}%</span>
                      </div>
                      <p class="text-[10px] text-gray-400 mt-1">
                        {route.completed_rooms}/{route.total_rooms} {lang === 'en' ? 'rooms' : 'salas'}
                        <span class={`ml-2 px-1.5 py-0.5 rounded text-[9px] font-bold ${
                          route.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'
                        }`}>
                          {route.status === 'active' ? (lang === 'en' ? 'Active' : 'Activa') : (lang === 'en' ? 'Completed' : 'Completada')}
                        </span>
                      </p>
                    </div>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </main>
</Layout>


<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL || "http://localhost:8000/v1/api";
  // Handle "Send Message" button — create direct conversation and redirect to chat
  document.querySelectorAll('[data-send-message-to]').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const targetUserId = (btn as HTMLElement).dataset.sendMessageTo;
      const token = localStorage.getItem('em_token');
      const lang = window.location.pathname.split('/')[1] || 'es';

      if (!token) {
        window.location.href = `/${lang}/login`;
        return;
      }

      try {
        const res = await fetch(`${API_BASE}/chat/conversations`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`,
          },
          body: JSON.stringify({ type: 'direct', target_user_id: targetUserId }),
        });

        if (res.ok) {
          window.location.href = `/${lang}/chat`;
        }
      } catch {
        window.location.href = `/${lang}/chat`;
      }
    });
  });
</script>
