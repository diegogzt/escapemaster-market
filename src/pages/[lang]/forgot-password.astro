---
import Layout from '../../layouts/Layout.astro';
import { ForgotPasswordForm } from '../../components/react/ForgotPasswordForm';

const { lang } = Astro.params;

const t = {
  title: 'Recuperar Contraseña'
};
---

<Layout title={`${t.title} | EscapeMaster`}>
  <main class="min-h-screen pt-16 sm:pt-20 pb-24 sm:pb-20 bg-tropical-bg flex items-start sm:items-center justify-center">
    <div class="w-full max-w-md mx-auto px-4 sm:px-0">
      <ForgotPasswordForm lang={lang || 'es'} client:load />
    </div>
  </main>
</Layout>
