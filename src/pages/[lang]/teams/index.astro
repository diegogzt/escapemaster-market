---
import Layout from '../../../layouts/Layout.astro';
import { pool } from '../../../lib/db';
import { ui } from '../../../i18n/ui';

const { lang = 'es' } = Astro.params;
const t = ui[lang as keyof typeof ui] || ui.es;

// Get search params
const url = new URL(Astro.request.url);
const search = url.searchParams.get('q') || '';

let squads: any[] = [];
try {
  let query = `
    SELECT s.*, 
      COUNT(sm.id) as member_count,
      (SELECT name FROM players WHERE id = s.leader_id) as leader_name
    FROM squads s
    LEFT JOIN squad_members sm ON sm.squad_id = s.id AND sm.status = 'active'
    WHERE s.is_public = true
  `;
  const params: any[] = [];
  
  if (search) {
    params.push(`%${search}%`);
    query += ` AND (s.name ILIKE $${params.length} OR s.description ILIKE $${params.length})`;
  }
  
  query += ` GROUP BY s.id ORDER BY s.total_games DESC, s.created_at DESC LIMIT 50`;
  
  const result = await pool.query(query, params);
  squads = result.rows;
} catch (e) {
  console.error('Error loading squads:', e);
}
---

<Layout title={`${t['teams.title']} | EscapeMaster`}>
  <main class="pt-24 pb-32 sm:pb-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      
      <!-- Header -->
      <div class="text-center mb-10">
        <h1 class="text-3xl sm:text-4xl font-black text-tropical-text mb-3">{t['teams.title']}</h1>
        <p class="text-tropical-text/60 max-w-xl mx-auto">{t['teams.subtitle']}</p>
      </div>

      <!-- Actions Bar -->
      <div class="flex flex-col sm:flex-row gap-4 mb-8">
        <!-- Search -->
        <form method="GET" class="flex-1">
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input 
              type="text" 
              name="q" 
              value={search}
              placeholder={t['teams.search'] + '...'}
              class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-tropical-primary focus:ring-2 focus:ring-tropical-primary/20 outline-none transition-all text-sm"
            />
          </div>
        </form>
        
        <!-- Action Buttons -->
        <div class="flex gap-3">
          <a 
            href={`/${lang}/teams/my-teams`}
            class="flex items-center gap-2 px-5 py-3 rounded-xl border border-gray-200 text-sm font-semibold text-tropical-text hover:bg-gray-50 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            {t['teams.my_teams']}
          </a>
          <a 
            href={`/${lang}/teams/create`}
            class="flex items-center gap-2 px-5 py-3 rounded-xl bg-tropical-primary text-white text-sm font-semibold hover:bg-tropical-primary/90 transition-colors shadow-lg shadow-tropical-primary/20"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
            {t['teams.create']}
          </a>
        </div>
      </div>

      <!-- Teams Grid -->
      {squads.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {squads.map((squad: any) => (
            <a href={`/${lang}/teams/${squad.id}`} class="group bg-white rounded-2xl border border-gray-100 p-6 hover:shadow-xl hover:border-tropical-primary/20 transition-all duration-300">
              <div class="flex items-start gap-4 mb-4">
                {squad.avatar_url ? (
                  <img src={squad.avatar_url} alt={squad.name} class="w-14 h-14 rounded-xl object-cover" />
                ) : (
                  <div class="w-14 h-14 rounded-xl bg-tropical-primary flex items-center justify-center text-white text-xl font-bold">
                    {squad.name.substring(0, 2).toUpperCase()}
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <h3 class="font-bold text-tropical-text text-lg group-hover:text-tropical-primary transition-colors truncate">{squad.name}</h3>
                  {squad.motto && <p class="text-sm text-tropical-text/50 italic truncate">"{squad.motto}"</p>}
                </div>
                <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-full ${squad.is_public ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                  {squad.is_public ? t['teams.public'] : t['teams.private']}
                </span>
              </div>
              
              {squad.description && (
                <p class="text-sm text-tropical-text/60 mb-4 line-clamp-2">{squad.description}</p>
              )}
              
              <div class="flex items-center gap-4 text-xs font-semibold text-tropical-text/40">
                <span class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                  {squad.member_count} {t['teams.members']}
                </span>
                <span class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  {squad.total_games} {t['teams.games_played']}
                </span>
                {squad.win_rate > 0 && (
                  <span class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 10 7 10"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 10 17 10"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
                    {squad.win_rate}% {t['teams.win_rate']}
                  </span>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-tropical-primary/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-tropical-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="text-xl font-bold text-tropical-text mb-2">{t['teams.no_teams']}</h3>
          <p class="text-tropical-text/50 mb-6">Crea tu equipo y empieza a jugar con amigos</p>
          <a 
            href={`/${lang}/teams/create`}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-tropical-primary text-white font-semibold hover:bg-tropical-primary/90 transition-colors shadow-lg shadow-tropical-primary/20"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
            {t['teams.create']}
          </a>
        </div>
      )}
    </div>
  </main>
</Layout>
