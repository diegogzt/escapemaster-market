---
import Layout from '../../../layouts/Layout.astro';
import { pool } from '../../../lib/db';
import { ui } from '../../../i18n/ui';

const { lang = 'es', id } = Astro.params;
const t = ui[lang as keyof typeof ui] || ui.es;

let squad: any = null;
let members: any[] = [];

try {
  const squadResult = await pool.query(`
    SELECT s.*, (SELECT name FROM players WHERE id = s.leader_id) as leader_name
    FROM squads s WHERE s.id = $1
  `, [id]);
  squad = squadResult.rows[0];

  if (squad) {
    const membersResult = await pool.query(`
      SELECT sm.*, p.name as player_name, p.avatar_url 
      FROM squad_members sm 
      LEFT JOIN players p ON p.id = sm.player_id 
      WHERE sm.squad_id = $1 AND sm.status = 'active'
      ORDER BY sm.role DESC, sm.joined_at ASC
    `, [id]);
    members = membersResult.rows;
  }
} catch (e) {
  console.error('Error loading squad:', e);
}

if (!squad) {
  return Astro.redirect(`/${lang}/teams`);
}
---

<Layout title={`${squad.name} | EscapeMaster`}>
  <main class="pb-32 sm:pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      
      <a href={`/${lang}/teams`} class="inline-flex items-center gap-2 text-sm font-semibold text-tropical-text/50 hover:text-tropical-primary mb-6 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        Volver a Equipos
      </a>

      <!-- Team Header -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6 sm:p-8 mb-6">
        <div class="flex items-start gap-5">
          {squad.avatar_url ? (
            <img src={squad.avatar_url} alt={squad.name} class="w-20 h-20 rounded-2xl object-cover shadow-lg" />
          ) : (
            <div class="w-20 h-20 rounded-2xl bg-tropical-primary flex items-center justify-center text-white text-3xl font-bold shadow-lg">
              {squad.name.substring(0, 2).toUpperCase()}
            </div>
          )}
          <div class="flex-1">
            <div class="flex items-start justify-between">
              <div>
                <h1 class="text-2xl sm:text-3xl font-black text-tropical-text">{squad.name}</h1>
                {squad.motto && <p class="text-tropical-text/50 italic mt-1">"{squad.motto}"</p>}
              </div>
              <span class={`text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full ${squad.is_public ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                {squad.is_public ? t['teams.public'] : t['teams.private']}
              </span>
            </div>
            {squad.description && <p class="text-sm text-tropical-text/60 mt-3">{squad.description}</p>}
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 mt-6 pt-6 border-t border-gray-100">
          <div class="text-center">
            <p class="text-2xl font-black text-tropical-primary">{members.length}</p>
            <p class="text-xs text-tropical-text/40 font-semibold uppercase tracking-wider">{t['teams.members']}</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-black text-tropical-primary">{squad.total_games || 0}</p>
            <p class="text-xs text-tropical-text/40 font-semibold uppercase tracking-wider">{t['teams.games_played']}</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-black text-tropical-primary">{squad.win_rate || 0}%</p>
            <p class="text-xs text-tropical-text/40 font-semibold uppercase tracking-wider">{t['teams.win_rate']}</p>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Members List -->
        <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 p-6">
          <h2 class="text-lg font-bold text-tropical-text mb-4">{t['teams.members']}</h2>
          
          {members.length > 0 ? (
            <div class="space-y-3">
              {members.map((member: any) => (
                <div class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors">
                  {member.avatar_url ? (
                    <img src={member.avatar_url} alt={member.player_name} class="w-10 h-10 rounded-full object-cover" />
                  ) : (
                    <div class="w-10 h-10 rounded-full bg-tropical-primary/10 flex items-center justify-center text-tropical-primary font-bold text-sm">
                      {(member.player_name || '?').substring(0, 2).toUpperCase()}
                    </div>
                  )}
                  <div class="flex-1">
                    <p class="font-semibold text-sm text-tropical-text">{member.player_name || 'Jugador'}</p>
                    <p class="text-xs text-tropical-text/40 capitalize">{member.role} · {member.synergy_count} sinergias</p>
                  </div>
                  {member.role === 'leader' && (
                    <span class="text-[10px] font-bold uppercase bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Líder</span>
                  )}
                </div>
              ))}
            </div>
          ) : (
            <p class="text-sm text-tropical-text/50 py-4">No hay miembros aún</p>
          )}
        </div>

        <!-- Invite Section -->
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <h2 class="text-lg font-bold text-tropical-text mb-4">{t['teams.invite']}</h2>
          
          {squad.invite_code ? (
            <div>
              <p class="text-sm text-tropical-text/60 mb-3">Comparte este código con tus amigos:</p>
              <div class="bg-gray-50 rounded-xl p-4 text-center">
                <p class="text-2xl font-mono font-bold text-tropical-primary tracking-widest" id="invite-code">{squad.invite_code}</p>
              </div>
              <button 
                id="copy-code" 
                class="w-full mt-3 py-2.5 rounded-xl border border-tropical-primary text-tropical-primary text-sm font-semibold hover:bg-tropical-primary/5 transition-colors"
              >
                Copiar código
              </button>
              
              <div class="mt-4 pt-4 border-t border-gray-100">
                <p class="text-xs text-tropical-text/40 mb-2">O comparte este enlace:</p>
                <div class="bg-gray-50 rounded-lg p-2 text-xs text-tropical-text/60 break-all" id="invite-link">
                  {`https://escapemaster.es/${lang}/teams?join=${squad.invite_code}`}
                </div>
              </div>
            </div>
          ) : (
            <p class="text-sm text-tropical-text/50">El equipo no tiene código de invitación activo</p>
          )}

          <div class="mt-6 pt-4 border-t border-gray-100">
            <button 
              id="join-btn"
              class="w-full py-3 rounded-xl bg-tropical-primary text-white font-semibold hover:bg-tropical-primary/90 transition-colors shadow-lg shadow-tropical-primary/20"
            >
              {t['teams.join']}
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>


<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL || "http://localhost:8000/v1/api";
  document.getElementById('copy-code')?.addEventListener('click', () => {
    const code = document.getElementById('invite-code')?.textContent || '';
    navigator.clipboard.writeText(code).then(() => {
      const btn = document.getElementById('copy-code')!;
      btn.textContent = '¡Copiado!';
      setTimeout(() => { btn.textContent = 'Copiar código'; }, 2000);
    });
  });

  document.getElementById('join-btn')?.addEventListener('click', async () => {
    const token = localStorage.getItem('em_token');
    if (!token) {
      const lang = window.location.pathname.split('/')[1] || 'es';
      window.location.href = `/${lang}/login`;
      return;
    }
    
    const squadId = window.location.pathname.split('/teams/')[1];
    try {
      const res = await fetch(`${API_BASE}/teams/${squadId}/join`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        window.location.reload();
      } else {
        const err = await res.json();
        alert(err.error || 'Error al unirse');
      }
    } catch {
      alert('Error de conexión');
    }
  });
</script>
