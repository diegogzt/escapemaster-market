---
import Layout from '../../../layouts/Layout.astro';
import { ui } from '../../../i18n/ui';

const { lang = 'es' } = Astro.params;
const t = ui[lang as keyof typeof ui] || ui.es;
---

<Layout title={`${t['teams.my_teams']} | EscapeMaster`}>
  <main class="pt-24 pb-32 sm:pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      
      <a href={`/${lang}/teams`} class="inline-flex items-center gap-2 text-sm font-semibold text-tropical-text/50 hover:text-tropical-primary mb-6 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        Volver a Equipos
      </a>

      <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl sm:text-3xl font-black text-tropical-text">{t['teams.my_teams']}</h1>
        <a 
          href={`/${lang}/teams/create`}
          class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-tropical-primary text-white text-sm font-semibold hover:bg-tropical-primary/90 transition-colors shadow-lg shadow-tropical-primary/20"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          {t['teams.create']}
        </a>
      </div>

      <div id="my-teams-container">
        <div class="text-center py-16">
          <div class="w-8 h-8 border-2 border-tropical-primary border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
          <p class="text-sm text-tropical-text/50">Cargando tus equipos...</p>
        </div>
      </div>
    </div>
  </main>
</Layout>


<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL || "http://localhost:8000/v1/api";
  async function loadMyTeams() {
    const container = document.getElementById('my-teams-container');
    const token = localStorage.getItem('em_token');
    
    if (!token) {
      container.innerHTML = `
        <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
          <p class="text-tropical-text/60 mb-4">Inicia sesión para ver tus equipos</p>
          <a href="/${lang}/login" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-tropical-primary text-white font-semibold hover:bg-tropical-primary/90 transition-colors">Iniciar Sesión</a>
        </div>
      `;
      return;
    }

    try {
      const res = await fetch(`${API_BASE}/teams/my-teams`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });

      if (!res.ok) throw new Error('Error');
      const teams = await res.json();

      if (teams.length === 0) {
        container.innerHTML = `
          <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
            <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-tropical-primary/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-tropical-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3 class="text-lg font-bold text-tropical-text mb-2">No tienes equipos aún</h3>
            <p class="text-tropical-text/50 mb-6">Crea un equipo o únete a uno existente</p>
            <a href="/${lang}/teams/create" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-tropical-primary text-white font-semibold hover:bg-tropical-primary/90 transition-colors shadow-lg shadow-tropical-primary/20">Crear Equipo</a>
          </div>
        `;
        return;
      }

      container.innerHTML = `
        <div class="space-y-4">
          ${teams.map(team => `
            <a href="/${lang}/teams/${team.id}" class="block bg-white rounded-2xl border border-gray-100 p-5 hover:shadow-lg hover:border-tropical-primary/20 transition-all">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-tropical-primary flex items-center justify-center text-white font-bold text-lg shrink-0">
                  ${team.name.substring(0, 2).toUpperCase()}
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-bold text-tropical-text">${team.name}</h3>
                  <p class="text-xs text-tropical-text/40">${team.member_count || 0} miembros · ${team.total_games || 0} partidas · ${team.role || 'member'}</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
              </div>
            </a>
          `).join('')}
        </div>
      `;
    } catch {
      container.innerHTML = `<p class="text-center py-8 text-red-500">Error al cargar equipos</p>`;
    }
  }

  loadMyTeams();
</script>
