---
import Layout from '../../../layouts/Layout.astro';
import { pool } from '../../../lib/db';
import { ui } from '../../../i18n/ui';
import { GameCard } from '../../../components/GameCard';
import { StartRouteButton } from '../../../components/react/StartRouteButton';
import { RouteMap } from '../../../components/react/RouteMap';
import { RoomReorder } from '../../../components/react/RoomReorder';
import { RouteBulkBooking } from '../../../components/react/RouteBulkBooking';

const { lang = 'es', slug } = Astro.params;
const t = ui[lang as keyof typeof ui] || ui.es;
const defaultRoomImage = 'https://images.unsplash.com/photo-1526498460520-4c246339dccb?auto=format&fit=crop&w=1200&q=80';

let collection: any = null;
let rooms: any[] = [];

try {
  const collResult = await pool.query(`
    SELECT * FROM curated_collections WHERE slug = $1 AND is_active = true
  `, [slug]);
  collection = collResult.rows[0];

  if (collection) {
    const roomsResult = await pool.query(`
      SELECT r.*, o.name as org_name, cr.featured_text, cr.display_order as route_order
      FROM collection_rooms cr
      JOIN rooms r ON r.id = cr.room_id
      LEFT JOIN organizations o ON o.id = r.organization_id
      WHERE cr.collection_id = $1 AND r.is_active = true
      ORDER BY cr.display_order ASC
    `, [collection.id]);
    rooms = roomsResult.rows;
  }
} catch (e) {
  console.error('Error loading route:', e);
}

if (!collection) {
  return Astro.redirect(`/${lang}/routes`);
}

const themeColor = collection.theme_color || '#0097b2';
const totalDuration = rooms.reduce((sum: number, r: any) => sum + (r.duration_minutes || 60), 0);
const avgRating = rooms.filter((r: any) => r.average_rating).length > 0
  ? (rooms.reduce((sum: number, r: any) => sum + (parseFloat(r.average_rating) || 0), 0) / rooms.filter((r: any) => r.average_rating).length).toFixed(1)
  : null;
const cities = [...new Set(rooms.map((r: any) => r.city).filter(Boolean))];
const normalizedRooms = rooms.map((room: any) => ({
  ...room,
  image_url: room.image_url || defaultRoomImage,
}));
---

<Layout title={`${collection.title} | EscapeMaster`}>
  <main class="pb-32 sm:pb-16">

    <!-- Cinematic Hero -->
    <section class="relative min-h-[55vh] sm:min-h-[65vh] flex items-end overflow-hidden">
      <img 
        src={collection.cover_image_url || collection.image_url || 'https://images.unsplash.com/photo-1518709766631-a6a7f45921c3?w=1200'} 
        alt={collection.title}
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-black/10"></div>
      
      <!-- Noise texture -->
      <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27noise%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.9%27 numOctaves=%274%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23noise)%27/%3E%3C/svg%3E');"></div>

      <!-- Theme color accent line at top -->
      <div class="absolute top-0 left-0 right-0 h-1" style={`background-color: ${themeColor}`}></div>

      <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 pb-10 sm:pb-14 pt-28">
        <!-- Breadcrumb -->
        <a href={`/${lang}/routes`} class="inline-flex items-center gap-2 text-white/50 hover:text-white text-sm font-medium mb-6 transition-colors group">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
          {lang === 'en' ? 'All routes' : 'Todas las rutas'}
        </a>

        <!-- Title area -->
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
          <div>
            {collection.is_featured && (
              <span class="inline-flex items-center gap-1.5 text-[10px] font-bold tracking-[0.15em] uppercase px-3 py-1 rounded-full mb-4" style={`background-color: ${themeColor}30; color: ${themeColor}`}>
                {t['routes.featured']}
              </span>
            )}
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-[0.95]">{collection.title}</h1>
            {collection.description && (
              <p class="text-base sm:text-lg text-white/50 mt-3 max-w-xl leading-relaxed">{collection.description}</p>
            )}
          </div>
        </div>

        <!-- Stats strip -->
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 mt-6">
          <div class="flex items-center gap-2 text-white/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span class="text-sm font-semibold">{rooms.length} {t['routes.rooms']}</span>
          </div>
          {avgRating && (
            <div class="flex items-center gap-1.5 text-white/70">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <span class="text-sm font-semibold">{avgRating}</span>
            </div>
          )}
          <div class="flex items-center gap-2 text-white/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span class="text-sm font-semibold">~{Math.round(totalDuration / 60)}h {totalDuration % 60}min total</span>
          </div>
          {cities.length > 0 && (
            <div class="flex items-center gap-2 text-white/70">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <span class="text-sm font-semibold">{cities.join(', ')}</span>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Action bar -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 -mt-5 relative z-10 mb-10">
      <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-4 sm:p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="flex-1">
          <StartRouteButton client:load collectionId={collection.id} lang={lang} />
        </div>
        <RoomReorder 
          client:load
          rooms={rooms.map((r: any) => ({
            id: r.id,
            name: r.name,
            city: r.city || '',
            image_url: r.image_url,
            org_name: r.org_name
          }))}
          collectionId={collection.id}
          lang={lang}
        />
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 mb-10">
      <RouteBulkBooking
        client:load
        lang={lang}
        rooms={normalizedRooms.map((room: any) => ({
          id: room.id,
          name: room.name,
          image_url: room.image_url,
          city: room.city || '',
          duration_minutes: room.duration_minutes,
          capacity_min: room.capacity_min,
          capacity: room.capacity,
        }))}
      />
    </section>

    <!-- Route Map -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style={`background-color: ${themeColor}20`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke={themeColor} stroke-width="2"><path d="M9 20l-5.447-2.724A1 1 0 0 1 3 16.382V5.618a1 1 0 0 1 1.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0 0 21 18.382V7.618a1 1 0 0 0-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        </div>
        <h2 class="text-xl font-black text-gray-900">{lang === 'en' ? 'Route Map' : 'Mapa de la Ruta'}</h2>
      </div>
      <RouteMap 
        client:load
        rooms={normalizedRooms.map((r: any, i: number) => ({
          id: r.id,
          name: r.name,
          city: r.city || '',
          latitude: r.latitude ? parseFloat(r.latitude) : null,
          longitude: r.longitude ? parseFloat(r.longitude) : null,
          image_url: r.image_url,
          org_name: r.org_name,
          order: i + 1
        }))}
        lang={lang}
        routeColor={themeColor}
      />
    </section>

    <!-- Rooms - Timeline style -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style={`background-color: ${themeColor}20`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke={themeColor} stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h2 class="text-xl font-black text-gray-900">{lang === 'en' ? 'Rooms in this route' : 'Salas de esta ruta'}</h2>
        <span class="text-sm text-gray-400 font-medium">({rooms.length})</span>
      </div>

      {rooms.length > 0 ? (
        <div class="space-y-4">
          {normalizedRooms.map((room: any, index: number) => (
            <a 
              href={`/${lang}/game/${room.id}`} 
              class="group flex flex-col sm:flex-row bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-xl hover:border-gray-200 transition-all duration-300"
            >
              <!-- Number + Timeline connector -->
              <div class="hidden sm:flex flex-col items-center w-16 py-6 flex-shrink-0">
                <div 
                  class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-black text-sm shadow-lg"
                  style={`background-color: ${themeColor}`}
                >
                  {index + 1}
                </div>
                {index < rooms.length - 1 && (
                  <div class="flex-1 w-px mt-2 opacity-30" style={`background-color: ${themeColor}; min-height: 20px;`}></div>
                )}
              </div>

              <!-- Image -->
              <div class="relative w-full sm:w-56 lg:w-72 aspect-[16/10] sm:aspect-auto sm:min-h-[180px] overflow-hidden flex-shrink-0">
                <img 
                  src={room.image_url || defaultRoomImage} 
                  alt={room.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
                <!-- Mobile number badge -->
                <div class="sm:hidden absolute top-3 left-3">
                  <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-black text-xs shadow-lg" style={`background-color: ${themeColor}`}>
                    {index + 1}
                  </div>
                </div>
                {room.featured_text && (
                  <div class="absolute top-3 right-3 text-white text-[10px] font-bold px-2.5 py-1 rounded-full shadow-lg" style={`background-color: ${themeColor}`}>
                    {room.featured_text}
                  </div>
                )}
                {room.difficulty_level && (
                  <div class="absolute bottom-3 left-3 sm:bottom-3 sm:left-3">
                    <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full backdrop-blur-sm ${
                      room.difficulty_level >= 4 ? 'bg-red-500/80 text-white' : 
                      room.difficulty_level >= 3 ? 'bg-orange-500/80 text-white' : 
                      'bg-green-500/80 text-white'
                    }`}>
                      {'★'.repeat(room.difficulty_level)} {lang === 'en' ? 'difficulty' : 'dificultad'}
                    </span>
                  </div>
                )}
              </div>

              <!-- Info -->
              <div class="flex-1 p-5 sm:p-6 flex flex-col justify-between min-w-0">
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-[0.15em] mb-1" style={`color: ${themeColor}`}>{room.org_name}</p>
                  <h3 class="font-bold text-lg text-gray-900 group-hover:text-tropical-primary transition-colors leading-tight">{room.name}</h3>
                  {room.description && (
                    <p class="text-sm text-gray-500 mt-1.5 line-clamp-2 leading-relaxed">{room.description}</p>
                  )}
                </div>
                
                <div class="flex flex-wrap items-center justify-between gap-3 mt-4 pt-3 border-t border-gray-100">
                  <div class="flex items-center gap-4 text-xs text-gray-500">
                    <span class="flex items-center gap-1">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      {room.duration_minutes || 60} min
                    </span>
                    <span class="flex items-center gap-1">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                      {room.capacity_min}-{room.capacity}
                    </span>
                    {room.city && (
                      <span class="flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                        {room.city}
                      </span>
                    )}
                    {room.average_rating && (
                      <span class="flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-yellow-500" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        <span class="font-bold text-gray-900">{room.average_rating}</span>
                        {room.total_reviews > 0 && <span class="text-gray-400">({room.total_reviews})</span>}
                      </span>
                    )}
                  </div>
                  
                  {room.price_per_person > 0 && (
                    <div class="text-right">
                      <p class="text-sm font-bold" style={`color: ${themeColor}`}>{room.price_per_person}€<span class="text-xs font-normal text-gray-400">/pers.</span></p>
                    </div>
                  )}
                </div>
              </div>

              <!-- Arrow -->
              <div class="hidden lg:flex items-center px-4 text-gray-300 group-hover:text-tropical-primary transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
          <p class="text-gray-500">{lang === 'en' ? 'No rooms in this route yet' : 'No hay salas en esta ruta'}</p>
        </div>
      )}
    </section>
  </main>
</Layout>
