---
import Layout from '../../layouts/Layout.astro';
import { ResetPasswordForm } from '../../components/react/ResetPasswordForm';

const { lang } = Astro.params;

const t = {
  title: 'Restablecer Contraseña'
};
---

<Layout title={`${t.title} | EscapeMaster`}>
  <main class="min-h-screen pt-24 sm:pt-32 pb-24 sm:pb-20 bg-[#FBF9F1] flex items-start sm:items-center justify-center">
    <div class="w-full max-w-md mx-auto px-4 sm:px-0">
      <ResetPasswordForm lang={lang || 'es'} client:load />
    </div>
  </main>
</Layout>
