---
import { ClientRouter } from 'astro:transitions';
import { Header } from '../components/Header';
import { ui } from '../i18n/ui';
import { Mail } from 'lucide-react';
import '../styles/global.css';
import { query } from '../lib/db';

interface Props {
	title: string;
	hideFooter?: boolean;
}

const { title, hideFooter = false } = Astro.props;
const { lang = 'es' } = Astro.params;
const t_nav = ui[lang as keyof typeof ui] || ui.es;

const t = {
    rights: '© 2026 EscapeMaster. Todos los derechos reservados.',
    brand: 'EscapeMaster',
    description: 'La plataforma líder para descubrir y reservar las mejores experiencias de Escape Room en España.',
    support: 'Soporte',
    legal: 'Legal',
    follow: 'Síguenos'
};

// Load branding & social links from platform_settings
let siteSettings: Record<string, string> = {};
try {
    const { rows } = await query(
        `SELECT key, value FROM platform_settings WHERE key IN ('logo_url','company_email','social_instagram','social_twitter','social_facebook','social_email')`
    );
    for (const r of rows) siteSettings[r.key] = r.value;
} catch (_) {}

const logoUrl = siteSettings['logo_url'] || '/logo.png';
const socialInstagram = siteSettings['social_instagram'] || '';
const socialTwitter = siteSettings['social_twitter'] || '';
const socialFacebook = siteSettings['social_facebook'] || '';
const socialEmail = siteSettings['social_email'] || siteSettings['company_email'] || 'info@escapemaster.es';

const prefix = lang === 'en' ? '/en' : '/es';
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href={logoUrl} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#0097b2" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<title>{title}</title>
        <ClientRouter />
		<script>
			// Initialize analytics tracking
			import { analytics } from '../lib/tracking';

			// Expose to window for use in islands
			window.analytics = analytics;

			// Track SPA navigation (Astro transitions)
			document.addEventListener('astro:page-load', () => {
				window.analytics?.trackPageView();
			});

			// Global click tracking for heatmap + navigation tracking
			document.addEventListener('click', (e) => {
				const target = e.target as HTMLElement;
				if (target) {
					// Track clicks on links and buttons
					if (target.tagName === 'A' || target.tagName === 'BUTTON' || target.closest('a') || target.closest('button')) {
						window.analytics?.trackClick(e.clientX, e.clientY, target.id || target.className);
					}
				}
			});
		</script>
	</head>
	<body class="bg-white text-tropical-text font-sans antialiased selection:bg-tropical-primary/10 transition-colors duration-500 overflow-x-hidden">
		<Header
			lang={lang}
			translations={{
				search: t_nav['nav.search'],
				teams: t_nav['nav.teams'],
				routes: t_nav['nav.routes'],
				offers: t_nav['nav.offers'],
				owner: t_nav['nav.owner'],
				login: t_nav['nav.login'],
			}}
			client:load
		/>
		
        <div class="animate-fade-in min-h-screen pt-24 sm:pt-28 lg:pt-32">
		    <slot />
        </div>
		
		{!hideFooter && <footer class="bg-white/50 backdrop-blur-sm border-t border-tropical-secondary/20 mt-20">
			<div class="max-w-7xl mx-auto px-6 py-16">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
                    <div class="space-y-6">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg overflow-hidden shadow-lg shrink-0">
                                <img src={logoUrl} alt={t.brand} class="w-full h-full object-contain" />
                            </div>
                            <span class="font-sans font-black text-xl text-tropical-primary">EscapeMaster</span>
                        </div>
                        <p class="text-tropical-text/70 text-sm leading-relaxed max-w-xs">{t.description}</p>
                    </div>

                    <div>
                        <h4 class="font-bold text-xs uppercase tracking-widest text-tropical-text/40 mb-6">{t.support}</h4>
                        <ul class="space-y-4">
                            <li><a href={`${prefix}/ayuda`} class="text-sm font-bold hover:text-tropical-primary transition-colors">Centro de Ayuda</a></li>
                            <li><a href={`${prefix}/contacto`} class="text-sm font-bold hover:text-tropical-primary transition-colors">Contacto</a></li>
                            <li><a href={`${prefix}/faq`} class="text-sm font-bold hover:text-tropical-primary transition-colors">Preguntas Frecuentes</a></li>
                        </ul>
                    </div>

                    <div>
                        <h4 class="font-bold text-xs uppercase tracking-widest text-tropical-text/40 mb-6">{t.legal}</h4>
                        <ul class="space-y-4">
                            <li><a href={`${prefix}/terminos`} class="text-sm font-bold hover:text-tropical-primary transition-colors">Términos y Condiciones</a></li>
                            <li><a href={`${prefix}/privacidad`} class="text-sm font-bold hover:text-tropical-primary transition-colors">Privacidad</a></li>
                            <li><a href={`${prefix}/cookies`} class="text-sm font-bold hover:text-tropical-primary transition-colors">Cookies</a></li>
                        </ul>
                    </div>

                    <div>
                        <h4 class="font-bold text-xs uppercase tracking-widest text-tropical-text/40 mb-6">{t.follow}</h4>
                        <div class="flex gap-4">
                            {socialInstagram && (
                            <a href={socialInstagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 rounded-xl bg-tropical-card flex items-center justify-center text-tropical-primary hover:bg-tropical-primary hover:text-white transition-all shadow-sm hover:shadow-md">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
                            </a>
                            )}
                            {socialTwitter && (
                            <a href={socialTwitter} target="_blank" rel="noopener noreferrer" aria-label="X / Twitter" class="w-10 h-10 rounded-xl bg-tropical-card flex items-center justify-center text-tropical-primary hover:bg-tropical-primary hover:text-white transition-all shadow-sm hover:shadow-md">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
                            </a>
                            )}
                            {socialFacebook && (
                            <a href={socialFacebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-10 h-10 rounded-xl bg-tropical-card flex items-center justify-center text-tropical-primary hover:bg-tropical-primary hover:text-white transition-all shadow-sm hover:shadow-md">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                            </a>
                            )}
                            <a href={`mailto:${socialEmail}`} aria-label="Email" class="w-10 h-10 rounded-xl bg-tropical-card flex items-center justify-center text-tropical-primary hover:bg-tropical-primary hover:text-white transition-all shadow-sm hover:shadow-md">
                                <Mail className="w-5 h-5" />
                            </a>
                        </div>
                    </div>
                </div>

                <div class="pt-8 border-t border-tropical-secondary/10">
    				<p class="text-tropical-text/40 text-xs font-bold uppercase tracking-widest text-center md:text-left">{t.rights}</p>
                </div>
			</div>
		</footer>}
	</body>
</html>

