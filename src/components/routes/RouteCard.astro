---
interface Props {
  collection: {
    id: string;
    title: string;
    slug: string;
    description?: string;
    cover_image_url?: string;
    image_url?: string;
    theme_color?: string;
    room_count: number;
    avg_rating?: number;
  };
  lang: string;
  t: any;
}

const { collection, lang, t } = Astro.props;

// SVG Icon Logic helper
const getRouteIcon = (slug: string) => {
  if (slug.includes('terror') || slug.includes('valientes')) 
    return `<path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"/><circle cx="12" cy="9" r="2.5" fill="white" stroke="none"/>`;
  if (slug.includes('principiantes') || slug.includes('familia')) 
    return `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`;
  if (slug.includes('mejor') || slug.includes('valorad')) 
    return `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`;
  if (slug.includes('madrid') || slug.includes('barcelona') || slug.includes('sur')) 
    return `<path d="M9 20l-5.447-2.724A1 1 0 0 1 3 16.382V5.618a1 1 0 0 1 1.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0 0 21 18.382V7.618a1 1 0 0 0-.553-.894L15 4m0 13V4m0 0L9 7"/>`;
  if (slug.includes('grupo')) 
    return `<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M12 8v8"/><path d="M8 12h8"/>`;
  return `<path d="M9 20l-5.447-2.724A1 1 0 0 1 3 16.382V5.618a1 1 0 0 1 1.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0 0 21 18.382V7.618a1 1 0 0 0-.553-.894L15 4m0 13V4m0 0L9 7"/>`;
};
---

<a 
  href={`/${lang}/routes/${collection.slug}`} 
  class="group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:border-tropical-primary/30 hover:shadow-xl transition-all duration-300 flex flex-col h-full"
>
  <!-- Image with color accent strip -->
  <div class="relative aspect-[16/9] overflow-hidden bg-gray-50">
    <img 
      src={collection.cover_image_url || collection.image_url || 'https://images.unsplash.com/photo-1518709766631-a6a7f45921c3?w=600'} 
      alt={collection.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      onload="this.style.opacity = '1'"
      onerror="this.src='https://images.unsplash.com/photo-1518709766631-a6a7f45921c3?w=600'; this.onerror=null;"
    />
    
    <!-- Top accent bar -->
    {collection.theme_color && (
      <div class="absolute top-0 left-0 right-0 h-1" style={`background-color: ${collection.theme_color}`}></div>
    )}
    
    <!-- Room count pill -->
    <div class="absolute bottom-3 left-3">
      <span class="bg-white/95 backdrop-blur-sm text-tropical-text text-[10px] font-black px-3 py-1 rounded-full shadow-sm flex items-center gap-1.5 uppercase tracking-wider">
        {collection.room_count} {t['routes.rooms']}
      </span>
    </div>
    
    <!-- Rating -->
    {collection.avg_rating && (
      <div class="absolute bottom-3 right-3 flex items-center gap-1 bg-white/95 backdrop-blur-sm px-2.5 py-1 rounded-full shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-tropical-accent" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span class="text-[10px] font-black text-tropical-text">{collection.avg_rating}</span>
      </div>
    )}
  </div>
  
  <!-- Content -->
  <div class="p-5 flex-1 flex flex-col">
    <div class="flex items-start justify-between gap-3 mb-3">
      <div class="flex-1 min-w-0">
        <h3 class="font-black text-lg text-tropical-text group-hover:text-tropical-primary transition-colors leading-tight">
          {collection.title}
        </h3>
      </div>
      <!-- Icon Container -->
      <div 
        class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" 
        style={`background-color: ${(collection.theme_color || '#0097b2')}10`}
      >
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          class="w-4 h-4" 
          fill="none" 
          viewBox="0 0 24 24" 
          stroke={collection.theme_color || '#0097b2'} 
          stroke-width="2.5" 
          set:html={getRouteIcon(collection.slug)} 
        />
      </div>
    </div>
    
    {collection.description && (
      <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed mb-4 flex-1">
        {collection.description}
      </p>
    )}
    
    <div class="flex items-center justify-between pt-4 border-t border-gray-50 mt-auto">
      <span class="text-xs font-black uppercase tracking-[0.1em] text-tropical-primary flex items-center gap-1">
        {t['routes.view']}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
      </span>
    </div>
  </div>
</a>
