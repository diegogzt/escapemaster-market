# ─────────────────────────────────────────────
# BASE DE DATOS — PostgreSQL (acceso directo para SSR)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/marketdb
BAUL_DATABASE_URL=postgresql://user:password@host:5432/marketdb

# ─────────────────────────────────────────────
# API — URL del servidor backend (web/api en port 8000)
# ─────────────────────────────────────────────
PUBLIC_API_URL=http://localhost:8000/v1/api

# ─────────────────────────────────────────────
# CMS API — URL del panel admin (master en port 4322)
# ─────────────────────────────────────────────
PUBLIC_CMS_API_URL=http://localhost:4322

# ─────────────────────────────────────────────
# PAGOS — Stripe (clave pública para Checkout)
# https://dashboard.stripe.com/apikeys
# ─────────────────────────────────────────────
PUBLIC_STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# GOOGLE OAUTH (login con Google)
# https://console.cloud.google.com/apis/credentials
# ─────────────────────────────────────────────
PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
